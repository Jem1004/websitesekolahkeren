---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../config/site';

// High-fidelity SEO metadata
const title = 'Video Animasi Promosi Web - websekolahkeren';
const description = 'Tonton video animasi interaktif yang mempromosikan websekolahkeren. Jelajahi fitur premium, CMS mudah, dan harga all-in dengan musik latar interaktif.';
---

<Layout {title} {description}>
  <Navbar />

  <main class="promo-page-container">
    <!-- Custom Glow Orbs for ambient tech vibes, styled to match websekolahkeren colors -->
    <div class="promo-bg-glow" id="pageBgGlow">
      <div class="glow-orb orange-glow"></div>
      <div class="glow-orb blue-glow"></div>
    </div>

    <div class="container container-content">
      
      <!-- Top Header (Hidden in Record Mode) -->
      <div class="promo-header text-center reveal-in">
        <span class="promo-badge">PROMOTION HUB</span>
        <h1>Video Animasi Promosi Premium</h1>
        <p class="lead-text">
          Pilih salah satu dari konsep video promosi websekolahkeren di bawah, sesuaikan format layar, lalu gunakan <strong>Mode Rekam</strong> untuk melakukan perekaman layar bersih yang luwes untuk media sosial Anda!
        </p>
      </div>

      <!-- CONCEPT SELECTOR TABS (Hidden in Record Mode) -->
      <div class="concept-selector-tabs reveal-in" id="conceptTabsContainer">
        <button class="concept-tab-btn active" data-concept="1" id="tabConcept1">
          <div class="icon-tab">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="m10 7 6 5-6 5V7z"></path>
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"></path>
            </svg>
          </div>
          <div class="tab-meta">
            <span class="tab-title">Konsep 1: Fitur Utama (Tema Gelap)</span>
            <span class="tab-desc">Animasi roket, keunggulan mockup responsif, & paket hemat. (40 Detik)</span>
          </div>
        </button>

        <button class="concept-tab-btn" data-concept="2" id="tabConcept2">
          <div class="icon-tab">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-2 10h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"></path>
            </svg>
          </div>
          <div class="tab-meta">
            <span class="tab-title">Konsep 2: Solusi WhatsApp (Tema Cerah)</span>
            <span class="tab-desc">Hook gelembung chat WA & Story cepat hilang. Solusi website abadi. (25 Detik)</span>
          </div>
        </button>
      </div>

      <!-- Main Video Showcase Arena -->
      <div class="video-arena">
        
        <!-- Video Box Wrapper (The target of formatting & recording) -->
        <div class="video-frame-wrapper shadow-epic ratio-16-9" id="videoWrapper">
          
          <!-- Inner Video Box where the animation happens -->
          <div class="video-content-box" id="videoBox" data-active-concept="1" data-active-scene="1">
            
            <!-- Record Mode Escape Badge (Only visible in Record Mode) -->
            <div class="record-badge" id="recordEscapeBadge">
              <span class="red-record-dot"></span>
              <span>Perekaman Aktif. Tekan <strong>ESC</strong> untuk Keluar</span>
            </div>

            <!-- Interactive Sparkle Particles Container -->
            <div class="particles-container" id="particlesContainer"></div>

            <!-- ========================================== -->
            <!-- CONCEPT 1 WRAPPER: FITUR UTAMA (DARK THEME) -->
            <!-- ========================================== -->
            <div class="concept-wrapper" id="concept1Wrapper">
              
              <!-- SCENE 1.1: THE PROBLEM (0s - 8s) -->
              <div class="scene scene-1" id="c1-scene1">
                <div class="sad-face-icon">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <circle cx="12" cy="12" r="10"></circle>
                    <path d="M8 14s1.5-2 4-2 4 2 4 2M9 9h.01M15 9h.01"></path>
                  </svg>
                </div>
                <div class="scene-title">Website Sekolah Lama Anda Bermasalah?</div>
                <div class="problem-cloud">
                  <span class="problem-tag tag-1">Tampilan Jadul</span>
                  <span class="problem-tag tag-2">Sangat Lambat</span>
                  <span class="problem-tag tag-3">Sulit Dikelola</span>
                  <span class="problem-tag tag-4">Harga Mahal</span>
                  <span class="problem-tag tag-5">Server Eror</span>
                </div>
                
                <!-- Simulated slow loading browser -->
                <div class="simulated-browser">
                  <div class="sb-header">
                    <div class="sb-dot"></div><div class="sb-dot"></div><div class="sb-dot"></div>
                    <div class="sb-url">sekolahkita-lama.sch.id</div>
                  </div>
                  <div class="sb-body">
                    <div class="spinner-loading"></div>
                    <div class="error-msg">Error 504: Gateway Timeout</div>
                  </div>
                </div>
              </div>

              <!-- SCENE 1.2: THE LAUNCH (8s - 14s) -->
              <div class="scene scene-2" id="c1-scene2">
                <div class="stars-sky"></div>
                
                <!-- Rocket Flying Group -->
                <div class="space-rocket-group" id="rocketGroup">
                  <svg width="180" height="180" viewBox="0 0 400 400" role="img" xmlns="http://www.w3.org/2000/svg">
                    <defs>
                      <radialGradient id="planetGrad" cx="35%" cy="30%" r="70%">
                        <stop offset="0%" stop-color="#2a1208"/>
                        <stop offset="45%" stop-color="#140600"/>
                        <stop offset="100%" stop-color="#050200"/>
                      </radialGradient>
                      <radialGradient id="glowRing" cx="50%" cy="50%" r="50%">
                        <stop offset="0%" stop-color="#F97316" stop-opacity="0.25"/>
                        <stop offset="100%" stop-color="#F97316" stop-opacity="0"/>
                      </radialGradient>
                      <radialGradient id="rocketBodyGrad" cx="30%" cy="30%" r="70%">
                        <stop offset="0%" stop-color="#ffffff"/>
                        <stop offset="100%" stop-color="#e2e8f0"/>
                      </radialGradient>
                    </defs>
                    
                    <circle cx="200" cy="200" r="140" fill="url(#glowRing)"/>
                    <ellipse cx="200" cy="200" rx="158" ry="46" fill="none" stroke="#ea580c" stroke-width="5" stroke-dasharray="248 248" opacity="0.45"/>
                    <circle cx="200" cy="200" r="100" fill="url(#planetGrad)"/>
                    <ellipse cx="200" cy="200" rx="158" ry="46" fill="none" stroke="#F97316" stroke-width="5" stroke-dasharray="248 248" stroke-dashoffset="248"/>
                    
                    <g class="inner-rocket" transform="translate(248, 92) rotate(45)">
                      <ellipse class="engine-flame" cx="0" cy="58" rx="8" ry="14" fill="#F97316"/>
                      <ellipse class="engine-flame-inner" cx="0" cy="62" rx="4" ry="8" fill="#ffffff"/>
                      <rect x="-13" y="-10" width="26" height="58" rx="6" fill="url(#rocketBodyGrad)"/>
                      <path d="M-13,-10 Q0,-44 13,-10 Z" fill="#ffffff"/>
                      <circle cx="0" cy="12" r="7" fill="#F97316"/>
                      <circle cx="0" cy="12" r="4.5" fill="#0f172a"/>
                      <circle cx="-1.5" cy="10" r="1.5" fill="#ffffff" opacity="0.7"/>
                      <path d="M-13,32 L-24,52 L-13,44 Z" fill="#ea580c"/>
                      <path d="M13,32 L24,52 L13,44 Z" fill="#ea580c"/>
                      <rect x="-13" y="22" width="26" height="5" fill="#F97316" opacity="0.7"/>
                    </g>
                  </svg>
                </div>

                <div class="solution-glow-text">
                  <div class="small-tag">MEMPERKENALKAN</div>
                  <div class="big-brand">web<span>sekolahkeren</span></div>
                </div>
              </div>

              <!-- SCENE 1.3: PREMIUM RESPONSIVE FEATURES (14s - 24s) -->
              <div class="scene scene-3" id="c1-scene3">
                <div class="features-title">Sempurna di Laptop, Tablet, & HP</div>
                
                <div class="device-mockups-container">
                  <div class="device-laptop">
                    <div class="dl-screen">
                      <div class="dl-topbar">
                        <span class="dot"></span><span class="dot"></span><span class="dot"></span>
                        <span class="url">demo4.websekolahkeren.id</span>
                      </div>
                      <img src="/demo4.png" alt="Laptop Preview" class="dl-img" />
                    </div>
                    <div class="dl-base"></div>
                  </div>
                  <div class="device-tablet">
                    <div class="dt-screen">
                      <img src="/demo1.png" alt="Tablet Preview" class="dt-img" />
                    </div>
                  </div>
                  <div class="device-phone">
                    <div class="dp-notch"></div>
                    <div class="dp-screen">
                      <img src="/demo2-mobile.png" alt="Phone Preview" class="dp-img" />
                    </div>
                  </div>
                </div>

                <div class="feature-bullets">
                  <div class="bullet-item"><span class="check-ico">✓</span> Desain Premium & Elegan</div>
                  <div class="bullet-item"><span class="check-ico">✓</span> CMS Mudah Dikelola Staf</div>
                  <div class="bullet-item"><span class="check-ico">✓</span> Server Super Cepat & Stabil</div>
                </div>
              </div>

              <!-- SCENE 1.4: TIMELINE & PRICING (24s - 32s) -->
              <div class="scene scene-4" id="c1-scene4">
                <div class="scene-title">Website Jadi Hanya Dalam 3 Hari Kerja!</div>
                
                <div class="animation-steps">
                  <div class="anim-step step-1">
                    <div class="step-badge">1</div>
                    <div class="step-txt">Pilih Desain</div>
                  </div>
                  <div class="anim-step step-2">
                    <div class="step-badge">2</div>
                    <div class="step-txt">Kirim Konten</div>
                  </div>
                  <div class="anim-step step-3">
                    <div class="step-badge">3</div>
                    <div class="step-txt">Review Kilat</div>
                  </div>
                  <div class="anim-step step-4">
                    <div class="step-badge">4</div>
                    <div class="step-txt">Website Live!</div>
                  </div>
                </div>

                <div class="price-showcase-card">
                  <div class="card-glow"></div>
                  <div class="p-eyebrow">PAKET ALL-IN TERIMA BERES</div>
                  <div class="p-cost">Rp 1,1 Juta<span> / Tahun</span></div>
                  <div class="p-features-mini">
                    <span>✦ Gratis Domain .sch.id</span>
                    <span>✦ Gratis Hosting & SSL Aman</span>
                    <span>✦ Bantuan Pelatihan CMS</span>
                  </div>
                </div>
              </div>

              <!-- SCENE 1.5: CALL TO ACTION (32s - 40s) -->
              <div class="scene scene-5" id="c1-scene5">
                <div class="stars-sky"></div>
                <div class="cta-logo">
                  <img src="/logo.svg" alt="websekolahkeren logo" class="cta-logo-img" />
                  <span>web<strong>sekolahkeren</strong></span>
                </div>
                <div class="cta-title">Siap Memiliki Website Sekolah Modern?</div>
                <p class="cta-desc">Hubungi tim kami hari ini dan lihat website sekolah Anda online maksimal 3 hari kerja.</p>
                <a href={SITE.contact.waUrl} target="_blank" class="wa-pulsate-btn shadow-epic">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.46 1.32 4.97L2 22l5.25-1.38a9.86 9.86 0 0 0 4.78 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.02A9.83 9.83 0 0 0 12.04 2zm5.79 14.18c-.25.69-1.44 1.34-2.01 1.4-.51.06-1.18.09-1.9-.12-.44-.13-1.01-.32-1.74-.63-3.06-1.32-5.06-4.4-5.21-4.61-.15-.2-1.24-1.65-1.24-3.14 0-1.5.79-2.24 1.07-2.55.28-.31.61-.39.81-.39h.59c.19 0 .44-.07.69.53.25.61.86 2.11.94 2.27.07.15.13.34.02.54-.1.2-.16.32-.31.5-.15.18-.32.4-.46.54-.15.15-.31.31-.13.61.18.31.79 1.31 1.7 2.12 1.17 1.05 2.16 1.37 2.46 1.52.31.15.49.13.67-.07.18-.2.78-.91.99-1.22.2-.31.41-.26.69-.16.28.1 1.78.84 2.08.99.31.15.51.23.59.36.07.13.07.74-.18 1.43z"></path>
                  </svg>
                  <span>Hubungi via WhatsApp (Terima Beres)</span>
                </a>
                <div class="wa-phone-number">Nomor Resmi: <strong>0877-8445-1080</strong></div>
              </div>

            </div>

            <!-- ============================================ -->
            <!-- CONCEPT 2 WRAPPER: SOLUSI PUBLIKASI WA (LIGHT) -->
            <!-- ============================================ -->
            <div class="concept-wrapper hide" id="concept2Wrapper">
              
              <!-- SCENE 2.1: THE WA OVERLOAD HOOK (0s - 7s) -->
              <div class="scene scene-1" id="c2-scene1">
                <div class="wa-chat-visualizer">
                  <div class="phone-frame-flat">
                    <div class="pf-header">
                      <span class="pf-title">WhatsApp Sekolah</span>
                      <span class="pf-status">online</span>
                    </div>
                    <div class="pf-body" id="whatsappChatsContainer">
                      <div class="chat-bubble left c2-tag-1">
                        <span class="chat-sender">Wakasek Humas</span>
                        <p>Bapak/Ibu, ini brosur pendaftaran PPDB Baru sekolah kita ya mohon dibagikan...</p>
                      </div>
                      <div class="chat-bubble left c2-tag-2">
                        <span class="chat-sender">Pembina OSIS</span>
                        <p>Dokumentasi foto lomba Matematika kemarin yang kita juara 1, silakan di-share di story!</p>
                      </div>
                      <div class="chat-bubble left c2-tag-3">
                        <span class="chat-sender">Operator Sekolah</span>
                        <p>Pengumuman kelulusan dan kalender akademik terbaru mohon disebarkan...</p>
                      </div>
                    </div>
                  </div>
                  
                  <!-- EXPIRING STORY CLOCK -->
                  <div class="story-expiry-visual" id="storyExpiryBox">
                    <div class="expiry-circle-ring">
                      <div class="expiry-pie"></div>
                      <span class="expiry-time">24 Jam</span>
                    </div>
                    <div class="expiry-label">Story WA Hilang!</div>
                  </div>
                </div>
                
                <div class="c2-bubble-warning-badge shadow-epic">Story Terhapus & Tenggelam Pesan Lain! ✕</div>
              </div>

              <!-- SCENE 2.2: THE SOLUTION REVEAL (7s - 13s) -->
              <div class="scene scene-2" id="c2-scene2">
                <div class="shining-portal-wrapper">
                  <div class="glow-portal"></div>
                  <!-- Floating rocket logo matching websekolahkeren orange brand icon -->
                  <div class="floating-logo-container float-soft">
                    <img src="/logo.svg" alt="websekolahkeren" class="flying-logo-icon" />
                  </div>
                </div>
                <div class="c2-solution-card">
                  <div class="c2-card-sub">JANGAN BIARKAN INFO SEKOLAH HILANG!</div>
                  <h2 class="c2-card-main">Website Sekolah Sendiri</h2>
                  <p class="c2-card-desc">Adalah Solusi Paling Relevan & Abadi</p>
                </div>
              </div>

              <!-- SCENE 2.3: ALWAYS ONLINE BENEFITS (13s - 19s) -->
              <div class="scene scene-3" id="c2-scene3">
                <div class="c2-bright-title">Semua Info Tersusun Rapi & Selalu Online</div>
                
                <div class="c2-features-grid">
                  <div class="c2-feat-card card-cyan shadow-soft">
                    <div class="c2-icon-wrap">📋</div>
                    <h3>PPDB Online</h3>
                    <p>Pendaftaran siswa baru tersistem rapi & aman.</p>
                  </div>
                  <div class="c2-feat-card card-emerald shadow-soft">
                    <div class="c2-icon-wrap">🏆</div>
                    <h3>Galeri Prestasi</h3>
                    <p>Dokumentasi piala dan prestasi siswa abadi.</p>
                  </div>
                  <div class="c2-feat-card card-amber shadow-soft">
                    <div class="c2-icon-wrap">📰</div>
                    <h3>Berita Kegiatan</h3>
                    <p>Publikasi acara & info penting langsung dibaca.</p>
                  </div>
                </div>

                <div class="c2-trust-row">
                  <span>✦ Mudah Diakses Orang Tua</span>
                  <span>✦ Meningkatkan Reputasi</span>
                  <span>✦ Terpercaya</span>
                </div>
              </div>

              <!-- SCENE 2.4: PENAWARAN & CTA (19s - 25s) -->
              <div class="scene scene-4" id="c2-scene4">
                <div class="c2-final-logo-row">
                  <img src="/logo.svg" alt="websekolahkeren" class="logo-mini-c2" />
                  <span>web<strong>sekolahkeren</strong></span>
                </div>
                <h2 class="c2-final-title">Tingkatkan Kredibilitas Sekolah Anda!</h2>
                
                <div class="c2-price-tag shadow-soft">
                  <span class="badge-tag">PROMO TERIMA BERES</span>
                  <div class="cost">Rp 1,1 Juta<span> / Tahun (All-In)</span></div>
                  <p class="meta">Desain Premium ✦ Domain .sch.id ✦ Hosting ✦ Selesai 3 Hari</p>
                </div>

                <a href={SITE.contact.waUrl} target="_blank" class="c2-wa-btn shadow-epic">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.46 1.32 4.97L2 22l5.25-1.38a9.86 9.86 0 0 0 4.78 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.02A9.83 9.83 0 0 0 12.04 2zm5.79 14.18c-.25.69-1.44 1.34-2.01 1.4-.51.06-1.18.09-1.9-.12-.44-.13-1.01-.32-1.74-.63-3.06-1.32-5.06-4.4-5.21-4.61-.15-.2-1.24-1.65-1.24-3.14 0-1.5.79-2.24 1.07-2.55.28-.31.61-.39.81-.39h.59c.19 0 .44-.07.69.53.25.61.86 2.11.94 2.27.07.15.13.34.02.54-.1.2-.16.32-.31.5-.15.18-.32.4-.46.54-.15.15-.31.31-.13.61.18.31.79 1.31 1.7 2.12 1.17 1.05 2.16 1.37 2.46 1.52.31.15.49.13.67-.07.18-.2.78-.91.99-1.22.2-.31.41-.26.69-.16.28.1 1.78.84 2.08.99.31.15.51.23.59.36.07.13.07.74-.18 1.43z"></path>
                  </svg>
                  <span>Hubungi via WhatsApp (Terima Beres)</span>
                </a>
                <div class="c2-phone-num">Nomor Layanan: <strong>0877-8445-1080</strong></div>
              </div>

            </div>

          </div>

          <!-- Video Playing Watermark (Only visible when playing/paused, hides in record mode) -->
          <div class="video-watermark" id="playerWatermark">
            <span class="w-brand">websekolahkeren</span>
            <span class="w-scene-num" id="watermarkSceneNum">Scene 1 / 5</span>
          </div>

          <!-- Large Play Overlay (Fades out when played) -->
          <div class="play-overlay" id="playOverlay">
            <div class="play-trigger-btn shadow-epic">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor">
                <path d="M8 5v14l11-7z"></path>
              </svg>
            </div>
            <span>Klik untuk Mulai Video Animasi & Musik</span>
          </div>

        </div>

        <!-- Pemutar Controls (Glassmorphic Bar below video) - Hidden in Record Mode -->
        <div class="player-controls-panel shadow-epic reveal-in" id="controlsPanel">
          
          <!-- Top row: Timeline progress -->
          <div class="timeline-row">
            <span class="time-lbl" id="timeCurrent">00:00</span>
            <div class="progress-bar-track" id="progressTrack">
              <div class="ticks-wrapper" id="ticksContainer">
                <!-- Ticks rendered dynamically in JS based on active concept -->
              </div>
              <div class="progress-bar-fill" id="progressBarFill"></div>
              <div class="progress-handle" id="progressHandle"></div>
            </div>
            <span class="time-lbl" id="timeDuration">00:40</span>
          </div>

          <!-- Bottom row: Buttons -->
          <div class="controls-action-row">
            <div class="control-group left">
              <!-- Play / Pause -->
              <button class="ctrl-btn" id="btnPlayPause" aria-label="Play or Pause">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="icon-play">
                  <path d="M8 5v14l11-7z"></path>
                </svg>
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="icon-pause hide">
                  <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"></path>
                </svg>
              </button>

              <!-- Restart -->
              <button class="ctrl-btn" id="btnRestart" aria-label="Restart Animation" title="Restart">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                  <path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"></path>
                </svg>
              </button>

              <!-- Sound Toggle -->
              <button class="ctrl-btn" id="btnSound" aria-label="Toggle Sound" title="Sound On/Off">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="icon-sound-off">
                  <path d="M11 5 6 9H2v6h4l5 4V5zM23 9l-6 6M17 9l6 6"></path>
                </svg>
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="icon-sound-on hide">
                  <path d="M11 5 6 9H2v6h4l5 4V5zM19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path>
                </svg>
              </button>
            </div>

            <!-- Scene direct selector buttons -->
            <div class="control-group center hide-tablet" id="sceneSelectorsContainer">
              <!-- Direct selectors rendered in JS -->
            </div>

            <div class="control-group right">
              <!-- Format layout change (Landscape / Portrait) -->
              <button class="ctrl-btn-action" id="btnToggleFormat" title="Ubah Rasio Layar Video">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <rect x="2" y="3" width="20" height="14" rx="2" class="ratio-horizontal-svg"></rect>
                  <rect x="5" y="2" width="14" height="20" rx="2" class="ratio-vertical-svg hide"></rect>
                </svg>
                <span id="formatText">Format Vertikal (9:16)</span>
              </button>

              <!-- Record mode (Red Pulsing dot) -->
              <button class="ctrl-btn-record" id="btnRecordMode" title="Nyalakan Layar Bersih untuk Merekam">
                <span class="record-red-dot"></span>
                <span>Mode Rekam</span>
              </button>
            </div>
          </div>

        </div>

      </div>

