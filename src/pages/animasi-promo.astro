  .progress-bar-track {
    position: relative;
    flex: 1;
    height: 6px;
    background: rgba(255,255,255,0.15);
    border-radius: 999px;
    cursor: pointer;
  }
  .progress-bar-fill {
    position: absolute;
    top: 0; left: 0;
    height: 100%;
    background: linear-gradient(90deg, var(--accent-2), #ea580c);
    border-radius: 999px;
    width: 0%;
  }

  /* Bright theme progress filler matches orange branding */
  .theme-bright ~ .player-controls-panel .progress-bar-fill {
    background: linear-gradient(90deg, var(--accent-2), #ea580c) !important;
  }

  .progress-handle {
    position: absolute;
    top: 50%;
    left: 0%;
    transform: translate(-50%, -50%);
    width: 14px; height: 14px;
    border-radius: 50%;
    background: #FFFFFF;
    box-shadow: 0 2px 8px rgba(0,0,0,0.5);
    cursor: grab;
  }

