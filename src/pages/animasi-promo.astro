</style>

<!-- Player timeline animation engine & Web Audio API sound designer code -->
<script>
  // Dynamic Timing Configurations (Narration text lists removed from UI overlay, kept only in console/logs for reference)
  const CONCEPT_DATA = {
    "1": {
      duration: 40,
      bpm: 90,
      bgmIntervalSec: 2.0,
      ticks: [
        { sec: 0, label: "1. Masalah" },
        { sec: 8, label: "2. Solusi" },
        { sec: 14, label: "3. Tampilan" },
        { sec: 24, label: "4. Harga" },
        { sec: 32, label: "5. Kontak" }
      ]
    },
    "2": {
      duration: 25,
      bpm: 125, // Upbeat dynamic speed
      bgmIntervalSec: 1.5, // Shorter interval between chord sweeps
      ticks: [
        { sec: 0, label: "1. Hook WA" },
        { sec: 7, label: "2. Solusi" },
        { sec: 13, label: "3. Manfaat" },
        { sec: 19, label: "4. Promo" }
      ]
    }
  };

  // Global player state
  let activeConcept: "1" | "2" = "1";
  let currentTime = 0;
  let isPlaying = false;
  let isMuted = true;
  let animationFrameId: number | null = null;
  let lastFrameTime = 0;

  // Web Audio Nodes
  let audioCtx: AudioContext | null = null;
  let masterGain: GainNode | null = null;
  let bgmInterval: any = null;
  let currentChordOscillators: OscillatorNode[] = [];

  // DOM Elements
  const videoBox = document.getElementById('videoBox') as HTMLDivElement;
  const videoWrapper = document.getElementById('videoWrapper') as HTMLDivElement;
  const timeCurrent = document.getElementById('timeCurrent') as HTMLSpanElement;
  const timeDuration = document.getElementById('timeDuration') as HTMLSpanElement;
  const progressBarFill = document.getElementById('progressBarFill') as HTMLDivElement;
  const progressHandle = document.getElementById('progressHandle') as HTMLDivElement;
  const progressTrack = document.getElementById('progressTrack') as HTMLDivElement;
  const btnPlayPause = document.getElementById('btnPlayPause') as HTMLButtonElement;
  const btnRestart = document.getElementById('btnRestart') as HTMLButtonElement;
  const btnSound = document.getElementById('btnSound') as HTMLButtonElement;
  const btnToggleFormat = document.getElementById('btnToggleFormat') as HTMLButtonElement;
  const btnRecordMode = document.getElementById('btnRecordMode') as HTMLButtonElement;
  const playOverlay = document.getElementById('playOverlay') as HTMLDivElement;
  const watermarkSceneNum = document.getElementById('watermarkSceneNum') as HTMLSpanElement;
  const formatText = document.getElementById('formatText') as HTMLSpanElement;
  
  // Toggles & Selection wrappers
  const ticksContainer = document.getElementById('ticksContainer') as HTMLDivElement;
  const sceneSelectorsContainer = document.getElementById('sceneSelectorsContainer') as HTMLDivElement;
  const concept1Wrapper = document.getElementById('concept1Wrapper') as HTMLDivElement;
  const concept2Wrapper = document.getElementById('concept2Wrapper') as HTMLDivElement;
  
  // Tabs UI buttons
  const tabConcept1 = document.getElementById('tabConcept1') as HTMLButtonElement;
  const tabConcept2 = document.getElementById('tabConcept2') as HTMLButtonElement;

  const iconPlay = btnPlayPause.querySelector('.icon-play') as SVGElement;
  const iconPause = btnPlayPause.querySelector('.icon-pause') as SVGElement;
  const iconSoundOff = btnSound.querySelector('.icon-sound-off') as SVGElement;
  const iconSoundOn = btnSound.querySelector('.icon-sound-on') as SVGElement;

  // -------------------------------------------------------------
  // CONCEPT SWAPPER LOGIC
  // -------------------------------------------------------------
  function switchConcept(conceptId: "1" | "2") {
    pauseVideo();
    activeConcept = conceptId;
    currentTime = 0;
    
    const config = CONCEPT_DATA[activeConcept];
    
    // 1. Update wrappers
    videoBox.setAttribute('data-active-concept', String(activeConcept));
    
    if (activeConcept === "1") {
      concept1Wrapper.classList.remove('hide');
      concept2Wrapper.classList.add('hide');
      videoBox.classList.remove('theme-bright');
      
      // Update page headers for orange accent
      document.getElementById('instructionsPanel')?.querySelectorAll('h3').forEach(el => el.style.color = 'var(--accent-2)');
      tabConcept1.classList.add('active');
      tabConcept2.classList.remove('active');
    } else {
      concept1Wrapper.classList.add('hide');
      concept2Wrapper.classList.remove('hide');
      videoBox.classList.add('theme-bright');
      
      // Update page headers for green accent
      document.getElementById('instructionsPanel')?.querySelectorAll('h3').forEach(el => el.style.color = 'var(--accent-2)');
      tabConcept1.classList.remove('active');
      tabConcept2.classList.add('active');
    }
    
    // 2. Redraw progress ticks and scene selector buttons
    renderTimelineControls();
    
    // 3. Update timing tags
    const minStr = String(Math.floor(config.duration / 60)).padStart(2, '0');
    const secStr = String(config.duration % 60).padStart(2, '0');
    timeDuration.innerText = `${minStr}:${secStr}`;
    
    updateUI();
  }

  // Draw scene tick indicators & scene selector buttons dynamically based on active concept metadata
  function renderTimelineControls() {
    const config = CONCEPT_DATA[activeConcept];
    
    // Clear old elements
    ticksContainer.innerHTML = "";
    sceneSelectorsContainer.innerHTML = "";
    
    config.ticks.forEach((tick, idx) => {
      const leftPct = (tick.sec / config.duration) * 100;
      
      // Progress tick marks
      const tickSpan = document.createElement('span');
      tickSpan.classList.add('scene-tick');
      tickSpan.style.left = `${leftPct}%`;
      tickSpan.title = tick.label;
      tickSpan.dataset.targetSec = String(tick.sec);
      tickSpan.addEventListener('click', (e) => {
        e.stopPropagation();
        currentTime = tick.sec;
        updateUI();
        if (!isPlaying) playVideo();
      });
      ticksContainer.appendChild(tickSpan);
      
      // Control panel selector button
      const selBtn = document.createElement('button');
      selBtn.classList.add('scene-select-btn');
      if (idx === 0) selBtn.classList.add('active');
      selBtn.innerText = tick.label;
      selBtn.dataset.scene = String(idx + 1);
      selBtn.addEventListener('click', () => {
        currentTime = tick.sec;
        updateUI();
        if (!isPlaying) playVideo();
      });
      sceneSelectorsContainer.appendChild(selBtn);
    });
  }

  // Bind concepts selector tab clicks
  tabConcept1.addEventListener('click', () => switchConcept("1"));
  tabConcept2.addEventListener('click', () => switchConcept("2"));

  // -------------------------------------------------------------
  // AUDIO SYNTHESIS ENGINE (WEB AUDIO API)
  // -------------------------------------------------------------
  function initAudio() {
    if (audioCtx) return;
    try {
      const AudioCtx = window.AudioContext || (window as any).webkitAudioContext;
      audioCtx = new AudioCtx();
      masterGain = audioCtx.createGain();
      
      // Master lowpass filter for analogue warmth
      const filter = audioCtx.createBiquadFilter();
      filter.type = 'lowpass';
      filter.frequency.setValueAtTime(1400, audioCtx.currentTime);
      
      masterGain.connect(filter);
      filter.connect(audioCtx.destination);
      masterGain.gain.setValueAtTime(isMuted ? 0 : 0.4, audioCtx.currentTime);
      
      // Sequencer kickoff
      startSequencer();
    } catch (e) {
      console.warn("Audio Context fails to load", e);
    }
  }

  function toggleSound() {
    isMuted = !isMuted;
    if (isMuted) {
      iconSoundOn.classList.add('hide');
      iconSoundOff.classList.remove('hide');
      if (masterGain && audioCtx) {
        masterGain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.1);
      }
    } else {
      iconSoundOff.classList.add('hide');
      iconSoundOn.classList.remove('hide');
      initAudio();
      if (audioCtx && audioCtx.state === 'suspended') {
        audioCtx.resume();
      }
      if (masterGain && audioCtx) {
        masterGain.gain.exponentialRampToValueAtTime(0.35, audioCtx.currentTime + 0.2);
      }
    }
  }

  // Play custom procedural sound effect
  function triggerSfx(type: string) {
    if (!audioCtx || isMuted) return;
    if (audioCtx.state === 'suspended') return;

    const now = audioCtx.currentTime;
    
    switch (type) {
      case 'alert': // Warning ring for problems
        const osc1 = audioCtx.createOscillator();
        const osc2 = audioCtx.createOscillator();
        const alertGain = audioCtx.createGain();
        
        osc1.type = 'sawtooth';
        osc1.frequency.setValueAtTime(160, now);
        osc2.type = 'square';
        osc2.frequency.setValueAtTime(164, now);
        
        alertGain.gain.setValueAtTime(0.2, now);
        alertGain.gain.linearRampToValueAtTime(0.001, now + 0.4);
        
        osc1.connect(alertGain);
        osc2.connect(alertGain);
        alertGain.connect(masterGain!);
        
        osc1.start(now);
        osc2.start(now);
        osc1.stop(now + 0.4);
        osc2.stop(now + 0.4);
        break;

      case 'swoosh': // Jet swoosh filter sweep (Rocket flying / portal solution)
        const bufferSize = audioCtx.sampleRate * 2.0;
        const noiseBuffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
        const data = noiseBuffer.getChannelData(0);
        for (let i = 0; i < bufferSize; i++) {
          data[i] = Math.random() * 2 - 1;
        }
        
        const whiteNoise = audioCtx.createBufferSource();
        whiteNoise.buffer = noiseBuffer;
        
        const noiseFilter = audioCtx.createBiquadFilter();
        noiseFilter.type = 'bandpass';
        noiseFilter.Q.setValueAtTime(2.0, now);
        noiseFilter.frequency.setValueAtTime(150, now);
        
        // Brighter sweeps for solution reveals
        const sweepEnd = activeConcept === "2" ? 3400 : 2200;
        noiseFilter.frequency.exponentialRampToValueAtTime(sweepEnd, now + 1.2);
        noiseFilter.frequency.exponentialRampToValueAtTime(300, now + 2.0);
        
        const noiseGain = audioCtx.createGain();
        noiseGain.gain.setValueAtTime(0.001, now);
        noiseGain.gain.linearRampToValueAtTime(0.35, now + 0.5);
        noiseGain.gain.exponentialRampToValueAtTime(0.001, now + 2.0);
        
        whiteNoise.connect(noiseFilter);
        noiseFilter.connect(noiseGain);
        noiseGain.connect(masterGain!);
        
        whiteNoise.start(now);
        whiteNoise.stop(now + 2.0);
        break;

      case 'pop': // Bubble pop sound for gelembung chats
        const popOsc = audioCtx.createOscillator();
        const popGain = audioCtx.createGain();
        
        popOsc.type = 'sine';
        const startFreq = activeConcept === "2" ? 320 : 180;
        const endFreq = activeConcept === "2" ? 950 : 650;
        popOsc.frequency.setValueAtTime(startFreq, now);
        popOsc.frequency.exponentialRampToValueAtTime(endFreq, now + 0.08);
        
        popGain.gain.setValueAtTime(0.2, now);
        popGain.gain.exponentialRampToValueAtTime(0.001, now + 0.09);
        
        popOsc.connect(popGain);
        popGain.connect(masterGain!);
        
        popOsc.start(now);
        popOsc.stop(now + 0.1);
        break;

      case 'chime': // Upbeat bright arpeggio chime chord representing female voice tone chimes
        const frequencies = activeConcept === "2" 
          ? [659.25, 783.99, 987.77, 1318.51] // E5, G5, B5, E6 (Bright high chimes)
          : [523.25, 659.25, 783.99, 1046.5];  // C5, E5, G5, C6 (Inspiring major chimes)
        
        frequencies.forEach((freq, index) => {
          const chimeOsc = audioCtx!.createOscillator();
          const chimeGain = audioCtx!.createGain();
          
          chimeOsc.type = 'sine';
          chimeOsc.frequency.setValueAtTime(freq, now + index * 0.05); // fast arpeggio
          
          chimeGain.gain.setValueAtTime(0.001, now);
          chimeGain.gain.linearRampToValueAtTime(0.12, now + index * 0.05 + 0.02);
          chimeGain.gain.exponentialRampToValueAtTime(0.001, now + index * 0.05 + 1.2);
          
          chimeOsc.connect(chimeGain);
          chimeGain.connect(masterGain!);
          
          chimeOsc.start(now);
          chimeOsc.stop(now + 2);
        });
        break;
    }
  }

  // Synthesizes the background looping music track prosedurally
  function startSequencer() {
    if (bgmInterval) clearInterval(bgmInterval);
    
    const config = CONCEPT_DATA[activeConcept];
    const intervalMs = config.bgmIntervalSec * 1000;
    
    bgmInterval = setInterval(() => {
      if (!isPlaying || !audioCtx || audioCtx.state === 'suspended') return;
      
      const now = audioCtx.currentTime;
      let chord: number[] = [];
      
      if (activeConcept === "1") {
        if (currentTime < 8) {
          chord = [130.81, 196.00, 311.13, 523.25]; // C Minor (Sad)
        } else if (currentTime >= 8 && currentTime < 14) {
          chord = [130.81, 196.00, 329.63, 523.25]; // C Major (Grand kickoff)
        } else if (currentTime >= 14 && currentTime < 24) {
          chord = [174.61, 261.63, 440.00, 698.46]; // F Major (Tech flow)
        } else if (currentTime >= 24 && currentTime < 32) {
          chord = [196.00, 293.66, 493.88, 783.99]; // G Major (Prices climb)
        } else {
          chord = [130.81, 196.00, 329.63, 392.00]; // C Major high (Conclusion)
        }
      } else {
        // Concept 2: Higher, lincah, bright Major progression representing voiceover wanita vibe
        if (currentTime < 7) {
          chord = [174.61, 349.23, 440.00, 523.25]; // F Major 4 (Tension/tick-tock)
        } else if (currentTime >= 7 && currentTime < 13) {
          chord = [261.63, 329.63, 392.00, 523.25]; // C Major (Portal solution reveal!)
        } else if (currentTime >= 13 && currentTime < 19) {
          chord = [220.00, 329.63, 440.00, 523.25]; // A Minor (Melodic expansion)
        } else {
          chord = [196.00, 293.66, 392.00, 493.88]; // G Major (Final happy CTA beat!)
        }
      }

      // Stop previous pads
      currentChordOscillators.forEach(osc => {
        try { osc.stop(now + 0.3); } catch(err){}
      });
      currentChordOscillators = [];

      // Trigger warm triangle waves for chord base
      chord.forEach(freq => {
        const osc = audioCtx!.createOscillator();
        const oscGain = audioCtx!.createGain();
        
        osc.type = 'triangle';
        osc.frequency.setValueAtTime(freq, now);
        
        oscGain.gain.setValueAtTime(0.001, now);
        const volumeFactor = activeConcept === "2" ? 0.045 : 0.05;
        oscGain.gain.linearRampToValueAtTime(volumeFactor, now + 0.6);
        oscGain.gain.exponentialRampToValueAtTime(0.001, now + config.bgmIntervalSec - 0.1);
        
        osc.connect(oscGain);
        oscGain.connect(masterGain!);
        
        osc.start(now);
        currentChordOscillators.push(osc);
      });

      // Procedural drum loops: faster and punchier in Concept 2!
      if (activeConcept === "1") {
        if (currentTime >= 14 && currentTime < 36) {
          triggerKick(now); triggerKick(now + 0.5); triggerKick(now + 1.0); triggerKick(now + 1.5);
          triggerSnap(now + 0.5); triggerSnap(now + 1.5);
        }
      } else {
        if (currentTime >= 7 && currentTime < 23) {
          const step = 60 / 125; // 0.48s per beat at 125 BPM
          triggerKick(now); triggerKick(now + step * 2);
          triggerSnap(now + step); triggerSnap(now + step * 3);
          // additional hihat shaker
          triggerSnap(now + step * 0.5); triggerSnap(now + step * 1.5);
        }
      }

    }, intervalMs);
  }

  function triggerKick(time: number) {
    if (!audioCtx || isMuted) return;
    const osc = audioCtx.createOscillator();
    const gain = audioCtx.createGain();
    
    const sweepEnd = activeConcept === "2" ? 50 : 40;
    osc.frequency.setValueAtTime(130, time);
    osc.frequency.exponentialRampToValueAtTime(sweepEnd, time + 0.08);
    
    gain.gain.setValueAtTime(0.24, time);
    gain.gain.exponentialRampToValueAtTime(0.001, time + 0.12);
    
    osc.connect(gain);
    gain.connect(masterGain!);
    osc.start(time);
    osc.stop(time + 0.13);
  }

  function triggerSnap(time: number) {
    if (!audioCtx || isMuted) return;
    const bufferSize = audioCtx.sampleRate * 0.04;
    const buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
    const data = buffer.getChannelData(0);
    for (let i = 0; i < bufferSize; i++) {
      data[i] = Math.random() * 2 - 1;
    }
    
    const noise = audioCtx.createBufferSource();
    noise.buffer = buffer;
    
    const filter = audioCtx.createBiquadFilter();
    filter.type = 'bandpass';
    filter.frequency.setValueAtTime(6500, time);
    
    const gain = audioCtx.createGain();
    gain.gain.setValueAtTime(0.06, time);
    gain.gain.exponentialRampToValueAtTime(0.001, time + 0.03);
    
    noise.connect(filter);
    filter.connect(gain);
    gain.connect(masterGain!);
    
    noise.start(time);
    noise.stop(time + 0.04);
  }

  // -------------------------------------------------------------
  // ANIMATION TIMELINE ENGINE & TIMEOUT MOTORS
  // -------------------------------------------------------------
  function updatePlayer(timestamp: number) {
    if (!isPlaying) return;
    
    if (!lastFrameTime) lastFrameTime = timestamp;
    const delta = (timestamp - lastFrameTime) / 1000;
    lastFrameTime = timestamp;
    
    currentTime += delta;
    
    const config = CONCEPT_DATA[activeConcept];
    if (currentTime >= config.duration) {
      pauseVideo();
      currentTime = config.duration;
      updateUI();
      return;
    }
    
    updateUI();
    animationFrameId = requestAnimationFrame(updatePlayer);
  }

  function updateUI() {
    const config = CONCEPT_DATA[activeConcept];
    
    // 1. Digital Time counter
    const minutes = Math.floor(currentTime / 60);
    const seconds = Math.floor(currentTime % 60);
    const formatTime = (num: number) => String(num).padStart(2, '0');
    timeCurrent.innerText = `${formatTime(minutes)}:${formatTime(seconds)}`;
    
    // 2. Progress track filling
    const ratio = Math.min(currentTime / config.duration, 1);
    progressBarFill.style.width = `${ratio * 100}%`;
    progressHandle.style.left = `${ratio * 100}%`;

    // 3. Scene switcher trigger
    let activeScene = 1;
    if (activeConcept === "1") {
      if (currentTime < 8) activeScene = 1;
      else if (currentTime >= 8 && currentTime < 14) activeScene = 2;
      else if (currentTime >= 14 && currentTime < 24) activeScene = 3;
      else if (currentTime >= 24 && currentTime < 32) activeScene = 4;
      else activeScene = 5;
    } else {
      if (currentTime < 7) activeScene = 1;
      else if (currentTime >= 7 && currentTime < 13) activeScene = 2;
      else if (currentTime >= 13 && currentTime < 19) activeScene = 3;
      else activeScene = 4;
    }
    
    const prevScene = videoBox.getAttribute('data-active-scene');
    if (prevScene !== String(activeScene)) {
      videoBox.setAttribute('data-active-scene', String(activeScene));
      const totalScenes = activeConcept === "1" ? 5 : 4;
      watermarkSceneNum.innerText = `Scene ${activeScene} / ${totalScenes}`;
      
      // Update ticks active selector button highlights
      document.querySelectorAll('.scene-select-btn').forEach((btn, idx) => {
        btn.classList.toggle('active', idx + 1 === activeScene);
      });
      
      // Spatial sound triggers
      if (activeConcept === "1") {
        if (activeScene === 1) triggerSfx('alert');
        if (activeScene === 2) triggerSfx('swoosh');
        if (activeScene === 3) {
          triggerSfx('pop');
          setTimeout(() => triggerSfx('pop'), 250);
          setTimeout(() => triggerSfx('pop'), 450);
        }
        if (activeScene === 4) triggerSfx('chime');
        if (activeScene === 5) triggerSfx('chime');
      } else {
        if (activeScene === 1) {
          triggerSfx('pop');
          setTimeout(() => triggerSfx('pop'), 1400);
          setTimeout(() => triggerSfx('pop'), 2800);
        }
        if (activeScene === 2) triggerSfx('swoosh');
        if (activeScene === 3) {
          triggerSfx('chime');
          setTimeout(() => triggerSfx('pop'), 200);
          setTimeout(() => triggerSfx('pop'), 400);
        }
        if (activeScene === 4) triggerSfx('chime');
      }
    }
    
    // Sparkle background generators
    if (isPlaying && Math.random() < 0.2) {
      createSparkleParticle();
    }
  }

  function createSparkleParticle() {
    const parent = document.getElementById('particlesContainer');
    if (!parent) return;
    
    const p = document.createElement('div');
    p.classList.add('sparkle-particle');
    
    const size = Math.random() * 6 + 2;
    const left = Math.random() * 100;
    const top = Math.random() * 100;
    
    p.style.width = `${size}px`;
    p.style.height = `${size}px`;
    p.style.left = `${left}%`;
    p.style.top = `${top}%`;
    p.style.opacity = '0';
    
    // Sparkle colors matches themes
    const color = activeConcept === "2"
      ? (Math.random() > 0.5 ? 'var(--accent-2)' : '#EFF6FF')
      : (Math.random() > 0.5 ? 'var(--accent-2)' : '#FFFFFF');
      
    p.style.background = color;
    p.style.transition = 'all 1.2s ease-out';
    
    parent.appendChild(p);
    
    setTimeout(() => {
      p.style.opacity = String(Math.random() * 0.7 + 0.3);
      p.style.transform = `translateY(-${Math.random() * 40 + 20}px) scale(1.5)`;
    }, 10);
    
    setTimeout(() => { p.remove(); }, 1200);
  }

  function playVideo() {
    isPlaying = true;
    playOverlay.classList.add('hide');
    iconPlay.classList.add('hide');
    iconPause.classList.remove('hide');
    
    initAudio();
    if (audioCtx && audioCtx.state === 'suspended') {
      audioCtx.resume();
    }
    
    lastFrameTime = 0;
    animationFrameId = requestAnimationFrame(updatePlayer);
  }

  function pauseVideo() {
    isPlaying = false;
    iconPause.classList.add('hide');
    iconPlay.classList.remove('hide');
    if (animationFrameId) {
      cancelAnimationFrame(animationFrameId);
      animationFrameId = null;
    }
  }

  function togglePlayPause() {
    if (isPlaying) {
      pauseVideo();
    } else {
      playVideo();
    }
  }

  function restartVideo() {
    pauseVideo();
    currentTime = 0;
    
    if (activeConcept === "2") {
      const pie = document.querySelector('.expiry-pie') as HTMLElement;
      if (pie) {
        pie.style.animation = 'none';
        void pie.offsetWidth;
        pie.style.animation = 'clockPie 7s linear forwards';
      }
    }
    
    updateUI();
    playVideo();
  }

  // Bind controls
  btnPlayPause.addEventListener('click', togglePlayPause);
  btnRestart.addEventListener('click', restartVideo);
  btnSound.addEventListener('click', toggleSound);
  playOverlay.addEventListener('click', playVideo);

  progressTrack.addEventListener('click', (e) => {
    const rect = progressTrack.getBoundingClientRect();
    const clickX = e.clientX - rect.left;
    const config = CONCEPT_DATA[activeConcept];
    const pct = Math.max(0, Math.min(clickX / rect.width, 1));
    currentTime = pct * config.duration;
    updateUI();
  });

  // Toggling Layout Ratios (Horizontal 16:9 / Vertical 9:16)
  btnToggleFormat.addEventListener('click', () => {
    const isHorizontal = videoWrapper.classList.contains('ratio-16-9');
    const svgHorizontal = btnToggleFormat.querySelector('.ratio-horizontal-svg') as SVGElement;
    const svgVertical = btnToggleFormat.querySelector('.ratio-vertical-svg') as SVGElement;

    if (isHorizontal) {
      videoWrapper.classList.remove('ratio-16-9');
      videoWrapper.classList.add('ratio-9-16');
      svgHorizontal.classList.add('hide');
      svgVertical.classList.remove('hide');
      formatText.innerText = "Format Lanskap (16:9)";
    } else {
      videoWrapper.classList.remove('ratio-9-16');
      videoWrapper.classList.add('ratio-16-9');
      svgVertical.classList.add('hide');
      svgHorizontal.classList.remove('hide');
      formatText.innerText = "Format Vertikal (9:16)";
    }
    updateUI();
  });

  // RECORD MODE ACTIVATION
  function enterRecordMode() {
    document.body.classList.add('record-active');
    restartVideo();
  }

  function exitRecordMode() {
    document.body.classList.remove('record-active');
    pauseVideo();
  }

  btnRecordMode.addEventListener('click', enterRecordMode);

  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      exitRecordMode();
    }
  });

  // Start initialization of defaults
  switchConcept("1");
</script>
