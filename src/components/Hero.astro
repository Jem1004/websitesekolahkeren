---
// Hero section — Marketing-optimized, premium, high-conversion.
---

<section class="hero-premium">
  <div class="container">
    <div class="hero-grid">
      
      <!-- Left: High-impact Sales Copy -->
      <div class="hero-text reveal">
        <div class="hero-badge">
          <span class="pulse-indicator"></span>
          <span class="badge-text">Layanan Pembuatan Website Sekolah</span>
        </div>
        
        <h1 class="headline-premium">
          Website Sekolah <span class="gradient-text">Modern & Profesional</span> Terima Beres
        </h1>
        
        <p class="lede-premium">
          Tingkatkan kredibilitas sekolah Anda dengan website yang tampil elegan dan sangat mudah dikelola. Tidak perlu pusing urusan teknis, kami siapkan semuanya dari desain, domain, hingga siap online.
        </p>
        
        <div class="hero-ctas">
          <a class="btn-premium" href="#demo">
            <span class="btn-glow"></span>
            <span class="btn-content">
              Lihat Demo Tampilan
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            </span>
          </a>
          <a class="btn-wa-outline" href="#kontak">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.46 1.32 4.97L2 22l5.25-1.38a9.86 9.86 0 0 0 4.78 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.02A9.83 9.83 0 0 0 12.04 2zm5.79 14.18c-.25.69-1.44 1.34-2.01 1.4-.51.06-1.18.09-1.9-.12-.44-.13-1.01-.32-1.74-.63-3.06-1.32-5.06-4.4-5.21-4.61-.15-.2-1.24-1.65-1.24-3.14 0-1.5.79-2.24 1.07-2.55.28-.31.61-.39.81-.39h.59c.19 0 .44-.07.69.53.25.61.86 2.11.94 2.27.07.15.13.34.02.54-.1.2-.16.32-.31.5-.15.18-.32.4-.46.54-.15.15-.31.31-.13.61.18.31.79 1.31 1.7 2.12 1.17 1.05 2.16 1.37 2.46 1.52.31.15.49.13.67-.07.18-.2.78-.91.99-1.22.2-.31.41-.26.69-.16.28.1 1.78.84 2.08.99.31.15.51.23.59.36.07.13.07.74-.18 1.43z"></path>
            </svg>
            Tanya via WhatsApp
          </a>
        </div>
        
        <ul class="trust-features">
          <li>
            <div class="check-box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg></div>
            <span><strong>Rp 1,1 Juta / Tahun</strong> (All-in tanpa biaya tersembunyi)</span>
          </li>
          <li>
            <div class="check-box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg></div>
            <span>Sudah termasuk <strong>Domain .sch.id & Hosting</strong></span>
          </li>
          <li>
            <div class="check-box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg></div>
            <span><strong>Terima Beres</strong>, website live maksimal 3 hari kerja</span>
          </li>
          <li>
            <div class="check-box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg></div>
            <span>Desain <strong>Responsif</strong> (Sempurna di HP & Laptop)</span>
          </li>
        </ul>
      </div>

      <!-- Right: Clean Premium Showcase -->
      <div class="hero-showcase reveal">
        <div class="showcase-glow-bg"></div>
        
        <!-- Main Laptop Mockup -->
        <div class="mockup-wrapper float-soft">
          <div class="mockup-laptop">
            <div class="laptop-screen">
              <div class="b-header">
                <div class="mac-dots"><span></span><span></span><span></span></div>
                <div class="b-url">smkimpian.sch.id</div>
              </div>
              <div class="b-body">
                <div class="ui-nav">
                  <div class="ui-logo">
                    <div class="ui-logo-icon"></div>
                    <div class="ui-logo-text"></div>
                  </div>
                  <div class="ui-links"><span></span><span></span><span></span></div>
                </div>
                <div class="ui-hero">
                  <div class="ui-hero-content">
                    <div class="ui-badge"></div>
                    <div class="ui-h1"></div>
                    <div class="ui-h1 short"></div>
                    <div class="ui-p"></div>
                    <div class="ui-p short"></div>
                    <div class="ui-btn primary"></div>
                  </div>
                  <div class="ui-hero-img"></div>
                </div>
                <div class="ui-cards">
                  <div class="ui-card"></div>
                  <div class="ui-card"></div>
                  <div class="ui-card"></div>
                </div>
              </div>
            </div>
            <div class="laptop-base">
              <div class="laptop-notch"></div>
            </div>
          </div>
        </div>
        
        <!-- Mobile Mockup Overlapping -->
        <div class="mockup-mobile float-soft-delayed">
          <div class="mobile-frame">
            <div class="mobile-notch"></div>
            <div class="mobile-screen">
              <div class="m-nav">
                <div class="ui-logo-icon small"></div>
                <div class="m-menu-icon"><span></span><span></span><span></span></div>
              </div>
              <div class="m-hero">
                <div class="ui-badge"></div>
                <div class="ui-h1"></div>
                <div class="ui-h1 short"></div>
                <div class="ui-p"></div>
                <div class="ui-p short"></div>
                <div class="ui-hero-img"></div>
                <div class="ui-btn primary full"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Floating Trust Chip -->
        <div class="glass-chip trust-chip float-hover">
          <div class="chip-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
              <polyline points="3.29 7 12 12 20.71 7"></polyline>
              <line x1="12" y1="22" x2="12" y2="12"></line>
            </svg>
          </div>
          <div class="chip-text">
            <strong>Bebas Pusing</strong>
            <span>Admin mudah digunakan</span>
          </div>
        </div>
        
      </div>

    </div>
  </div>
</section>

<style>
  /* Base Hero Adjustments */
  .hero-premium {
    padding: 160px 0 100px;
    position: relative;
    overflow: hidden;
  }
  
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  @media (max-width: 992px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 100px;
    }
  }

  /* ── Left Side (Marketing Copy) ── */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px;
    background: color-mix(in oklab, var(--accent) 15%, transparent);
    border: 1px solid color-mix(in oklab, var(--accent) 30%, transparent);
    border-radius: 999px;
    margin-bottom: 32px;
  }
  
  .pulse-indicator {
    width: 8px;
    height: 8px;
    background: var(--accent);
    border-radius: 50%;
    box-shadow: 0 0 0 0 color-mix(in oklab, var(--accent) 60%, transparent);
    animation: badgePulse 2s infinite;
  }
  
  @keyframes badgePulse {
    0% { box-shadow: 0 0 0 0 color-mix(in oklab, var(--accent) 60%, transparent); }
    70% { box-shadow: 0 0 0 8px color-mix(in oklab, var(--accent) 0%, transparent); }
    100% { box-shadow: 0 0 0 0 color-mix(in oklab, var(--accent) 0%, transparent); }
  }

  .badge-text {
    font-size: 13px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.02em;
  }

  .headline-premium {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
    text-wrap: balance;
  }

  .lede-premium {
    font-size: 18px;
    line-height: 1.65;
    color: var(--text-2);
    margin-bottom: 40px;
    max-width: 520px;
  }

  /* CTAs */
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 40px;
  }

  .btn-premium {
    position: relative;
    display: inline-flex;
    padding: 16px 28px;
    border-radius: 16px;
    background: var(--accent);
    color: #fff;
    font-weight: 700;
    font-size: 16px;
    text-decoration: none;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 8px 24px -8px var(--accent-glow);
  }
  
  .btn-premium:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px -8px var(--accent-glow);
  }

  .btn-glow {
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent, rgba(255,255,255,0.3), transparent);
    transform: translateX(-100%);
    transition: transform 0.6s;
  }
  
  .btn-premium:hover .btn-glow {
    transform: translateX(100%);
  }

  .btn-content {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .btn-wa-outline {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 24px;
    border-radius: 16px;
    background: transparent;
    border: 1px solid var(--border-strong);
    color: var(--text);
    font-weight: 600;
    font-size: 16px;
    text-decoration: none;
    transition: all 0.2s;
  }
  
  .btn-wa-outline:hover {
    border-color: var(--wa-green);
    color: var(--wa-green);
    background: color-mix(in oklab, var(--wa-green) 5%, transparent);
  }
  
  .btn-wa-outline svg {
    color: var(--wa-green);
  }

  /* Trust Features List */
  .trust-features {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .trust-features li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 15px;
    line-height: 1.5;
    color: var(--text-2);
  }
  
  .trust-features strong {
    color: var(--text);
    font-weight: 700;
  }

  .check-box {
    width: 22px;
    height: 22px;
    border-radius: 6px;
    background: var(--accent-soft);
    color: var(--accent);
    display: grid;
    place-items: center;
    flex-shrink: 0;
    margin-top: 1px;
  }
  
  .check-box svg {
    width: 14px;
    height: 14px;
  }

  /* ── Right Side: Showcase (Laptop & Mobile) ── */
  .hero-showcase {
    position: relative;
    height: 480px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .showcase-glow-bg {
    position: absolute;
    width: 450px;
    height: 450px;
    background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 0;
    filter: blur(50px);
  }

  /* Laptop Mockup */
  .mockup-wrapper {
    position: absolute;
    z-index: 1;
    width: 115%;
    max-width: 600px;
    left: 0;
    transform-origin: center;
  }

  .mockup-laptop {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .laptop-screen {
    width: 100%;
    aspect-ratio: 16/10;
    background: var(--bg);
    border: 8px solid #2a2a2a;
    border-radius: 16px 16px 0 0;
    overflow: hidden;
    position: relative;
    box-shadow: 0 20px 40px -10px rgba(0,0,0,0.5);
  }
  [data-theme="light"] .laptop-screen { border-color: #d1d5db; box-shadow: 0 20px 40px -10px rgba(0,0,0,0.15); }

  .laptop-base {
    width: 112%;
    height: 14px;
    background: #404040;
    border-radius: 0 0 16px 16px;
    position: relative;
    box-shadow: inset 0 2px 0 rgba(255,255,255,0.1);
  }
  [data-theme="light"] .laptop-base { background: #9ca3af; box-shadow: inset 0 2px 0 rgba(255,255,255,0.5); }
  
  .laptop-notch {
    width: 80px;
    height: 6px;
    background: #2a2a2a;
    margin: 0 auto;
    border-radius: 0 0 6px 6px;
  }
  [data-theme="light"] .laptop-notch { background: #d1d5db; }

  /* Browser Inside Laptop */
  .b-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 12px;
    background: var(--surface-2);
    border-bottom: 1px solid var(--border);
  }
  .mac-dots { display: flex; gap: 5px; }
  .mac-dots span { width: 8px; height: 8px; border-radius: 50%; }
  .mac-dots span:nth-child(1) { background: #ef4444; }
  .mac-dots span:nth-child(2) { background: #eab308; }
  .mac-dots span:nth-child(3) { background: #22c55e; }
  
  .b-url {
    flex: 1;
    background: var(--bg);
    border-radius: 4px;
    padding: 4px;
    text-align: center;
    font-size: 9px;
    color: var(--text-3);
    font-family: monospace;
    border: 1px solid var(--border);
  }

  .b-body {
    padding: 16px;
    background: var(--surface);
    height: calc(100% - 30px);
    display: flex; flex-direction: column; gap: 20px;
  }

  /* Mini UI styling */
  .ui-nav { display: flex; justify-content: space-between; align-items: center; }
  .ui-logo { display: flex; align-items: center; gap: 6px; }
  .ui-logo-icon { width: 18px; height: 18px; background: var(--accent); border-radius: 4px; }
  .ui-logo-text { width: 60px; height: 8px; background: var(--text); border-radius: 2px; }
  .ui-links { display: flex; gap: 10px; }
  .ui-links span { width: 24px; height: 4px; background: var(--surface-2); border-radius: 2px; }

  .ui-hero { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; align-items: center; }
  .ui-badge { width: 60px; height: 12px; background: var(--accent-soft); border-radius: 999px; margin-bottom: 10px; }
  .ui-h1 { width: 100%; height: 16px; background: var(--text); border-radius: 4px; margin-bottom: 8px; }
  .ui-h1.short { width: 70%; }
  .ui-p { width: 100%; height: 6px; background: var(--text-3); border-radius: 2px; margin-bottom: 6px; }
  .ui-p.short { width: 80%; }
  .ui-btn { width: 70px; height: 24px; border-radius: 6px; margin-top: 12px; }
  .ui-btn.primary { background: var(--accent); }
  .ui-btn.full { width: 100%; }
  
  .ui-hero-img { width: 100%; aspect-ratio: 4/3; background: var(--surface-2); border-radius: 8px; }

  .ui-cards { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; }
  .ui-card { height: 40px; background: var(--surface-2); border-radius: 6px; }

  /* Mobile Mockup */
  .mockup-mobile {
    position: absolute;
    z-index: 2;
    right: -5%;
    bottom: -5%;
    width: 140px;
  }

  .mobile-frame {
    width: 100%;
    aspect-ratio: 9/19;
    background: var(--bg);
    border: 6px solid #1a1a1a;
    border-radius: 24px;
    box-shadow: 0 24px 50px -10px rgba(0,0,0,0.5);
    position: relative;
    overflow: hidden;
  }
  [data-theme="light"] .mobile-frame { border-color: #d1d5db; box-shadow: 0 24px 50px -10px rgba(0,0,0,0.2); }

  .mobile-notch {
    position: absolute;
    top: 0; left: 50%; transform: translateX(-50%);
    width: 40%; height: 12px;
    background: #1a1a1a;
    border-radius: 0 0 8px 8px;
    z-index: 10;
  }
  [data-theme="light"] .mobile-notch { background: #d1d5db; }

  .mobile-screen {
    width: 100%; height: 100%;
    background: var(--surface);
    padding: 24px 12px 12px;
    display: flex; flex-direction: column; gap: 16px;
  }
  .m-nav { display: flex; justify-content: space-between; align-items: center; }
  .ui-logo-icon.small { width: 14px; height: 14px; }
  .m-menu-icon { display: flex; flex-direction: column; gap: 2px; }
  .m-menu-icon span { width: 12px; height: 2px; background: var(--text); border-radius: 1px; }

  .m-hero { display: flex; flex-direction: column; align-items: center; text-align: center; }
  .m-hero .ui-h1, .m-hero .ui-p, .m-hero .ui-badge { margin-left: auto; margin-right: auto; }
  .m-hero .ui-hero-img { margin-top: 12px; aspect-ratio: 16/9; }
  .m-cards { display: flex; flex-direction: column; gap: 8px; margin-top: 10px; }

  /* Floating Trust Chip */
  .glass-chip {
    position: absolute;
    top: 5%;
    right: 0%;
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: color-mix(in oklab, var(--surface) 85%, transparent);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--border-strong);
    border-radius: 16px;
    box-shadow: 0 16px 32px -8px rgba(0,0,0,0.2);
  }
  [data-theme="light"] .glass-chip { box-shadow: 0 16px 32px -8px rgba(15,23,42,0.1); }
  
  .chip-icon {
    width: 32px; height: 32px;
    background: var(--accent-soft);
    color: var(--accent);
    border-radius: 10px;
    display: grid; place-items: center;
  }
  .chip-text { display: flex; flex-direction: column; }
  .chip-text strong { font-size: 13px; color: var(--text); font-weight: 700; }
  .chip-text span { font-size: 11px; color: var(--text-3); }

  /* Floating Animations */
  @keyframes float-soft { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }
  @keyframes float-soft-delayed { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-15px); } }
  @keyframes float-hover { 0%, 100% { transform: translateY(0) rotate(2deg); } 50% { transform: translateY(-8px) rotate(-1deg); } }

  .float-soft { animation: float-soft 6s ease-in-out infinite; }
  .float-soft-delayed { animation: float-soft-delayed 7s ease-in-out infinite 1s; }
  .float-hover { animation: float-hover 5s ease-in-out infinite 2s; }
  
  @media (prefers-reduced-motion: reduce) {
    .float-soft, .float-soft-delayed, .float-hover, .pulse-indicator { animation: none; transform: none !important; }
  }

  /* Responsive fixes */
  @media (max-width: 640px) {
    .hero-premium { padding: 140px 0 80px; }
    .hero-ctas { flex-direction: column; }
    .btn-premium, .btn-wa-outline { width: 100%; justify-content: center; }
    
    .hero-showcase { height: 320px; }
    .mockup-wrapper { width: 120%; left: -10%; }
    .mockup-mobile { width: 100px; right: 0; bottom: -10%; }
    .glass-chip { top: -10%; right: auto; left: 10%; transform: scale(0.9); }
  }
</style>
