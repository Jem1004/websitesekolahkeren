---
// Hero section — kept identical in markup to the source design.
---

<section class="hero">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-text reveal">
        <div class="hero-eyebrow">
          <span class="pill">Baru 2026</span>
          <span>Dibangun dengan Next.js · SEO-ready · Cloud storage</span>
        </div>
        <h1>
          Website Sekolah Modern, <br />
          <span class="gradient-text">Langsung Jadi &amp; Mudah Dikelola</span>
        </h1>
        <p class="lede">
          Hadirkan wajah digital sekolah Anda yang profesional dengan sistem manajemen konten (CMS) modern.
          Update berita, galeri, dan profil sekolah — tanpa coding, tanpa repot menghubungi developer.
        </p>
        <div class="hero-ctas">
          <a class="btn btn-primary btn-lg" href="#demo">
            Lihat Demo Tampilan
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </a>
          <a class="btn btn-wa btn-lg" href="#kontak">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.46 1.32 4.97L2 22l5.25-1.38a9.86 9.86 0 0 0 4.78 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.02A9.83 9.83 0 0 0 12.04 2zm5.79 14.18c-.25.69-1.44 1.34-2.01 1.4-.51.06-1.18.09-1.9-.12-.44-.13-1.01-.32-1.74-.63-3.06-1.32-5.06-4.4-5.21-4.61-.15-.2-1.24-1.65-1.24-3.14 0-1.5.79-2.24 1.07-2.55.28-.31.61-.39.81-.39h.59c.19 0 .44-.07.69.53.25.61.86 2.11.94 2.27.07.15.13.34.02.54-.1.2-.16.32-.31.5-.15.18-.32.4-.46.54-.15.15-.31.31-.13.61.18.31.79 1.31 1.7 2.12 1.17 1.05 2.16 1.37 2.46 1.52.31.15.49.13.67-.07.18-.2.78-.91.99-1.22.2-.31.41-.26.69-.16.28.1 1.78.84 2.08.99.31.15.51.23.59.36.07.13.07.74-.18 1.43z"></path>
            </svg>
            Konsultasi via WhatsApp
          </a>
        </div>
        <ul class="trust-badges">
          <li><span class="check">✓</span> Harga mulai Rp 1,1 Juta</li>
          <li><span class="check">✓</span> Domain &amp; Hosting opsional</li>
          <li><span class="check">✓</span> Support &amp; revisi tersedia</li>
          <li><span class="check">✓</span> Teknologi Next.js modern</li>
        </ul>
      </div>

      <div class="device-stack reveal">
        <div class="float-chip chip-1">
          <span class="ico">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2v4"></path><path d="M12 18v4"></path>
              <path d="m4.93 4.93 2.83 2.83"></path><path d="m16.24 16.24 2.83 2.83"></path>
              <path d="M2 12h4"></path><path d="M18 12h4"></path>
              <path d="m4.93 19.07 2.83-2.83"></path><path d="m16.24 7.76 2.83-2.83"></path>
            </svg>
          </span>
          <div>Performa<small>Lighthouse 98+</small></div>
        </div>
        <div class="float-chip chip-2">
          <span class="ico">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
          </span>
          <div>RBAC Aktif<small>3 level akses</small></div>
        </div>
        <div class="browser" aria-hidden="true">
          <div class="browser-bar">
            <div class="browser-dots"><span></span><span></span><span></span></div>
            <div class="browser-url">smkimpian.sch.id</div>
          </div>
          <div class="browser-body">
            <div class="site-preview">
              <div class="sp-nav">
                <div class="lg"><span class="lg-mark"></span> SMK Impian</div>
                <div class="links">Beranda · Berita · Profil · PPDB</div>
              </div>
              <div class="sp-hero">
                <div>
                  <h3>Membangun Generasi Siap Industri</h3>
                  <p>Pendaftaran Peserta Didik Baru 2026/2027 telah dibuka — bergabung jadi bagian keluarga besar kami.</p>
                  <div class="badge-set"><span>Akreditasi A</span><span>5 Jurusan</span></div>
                </div>
                <button class="btn-mini" type="button">Daftar PPDB →</button>
              </div>
              <div class="sp-cards">
                <div class="sp-card"><span class="ico"></span><span class="t">Berita</span><span class="s">Lomba inovasi tingkat nasional 2026</span></div>
                <div class="sp-card"><span class="ico"></span><span class="t">Galeri</span><span class="s">Dokumentasi kegiatan terbaru</span></div>
                <div class="sp-card"><span class="ico"></span><span class="t">Profil</span><span class="s">Visi misi &amp; sambutan kepsek</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
