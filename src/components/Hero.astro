---
// Hero section — Ultra-clean, professional, and highly conversion-optimized (Sales-focused).
// Uses a split layout with a pristine multi-device showcase (Laptop, Tablet, Mobile) to prove responsiveness.
---

<section class="hero-pro">
  <div class="hero-bg">
    <div class="hero-glow"></div>
  </div>

  <div class="container-wide relative-z">
    <div class="hero-grid">
      
      <!-- Left Side: Marketing Copy -->
      <div class="hero-content reveal">
        
        <div class="pro-badge">
          <span class="pulse-dot"></span>
          Layanan Pembuatan Website Sekolah
        </div>
        
        <h1 class="pro-title">
          Website Sekolah <br class="hide-mobile"/>
          <span class="text-highlight">Modern & Profesional</span> <br class="hide-mobile"/>
          Terima Beres
        </h1>
        
        <p class="pro-desc">
          Tingkatkan kredibilitas sekolah Anda dengan website elegan dan mudah dikelola. Tidak perlu pusing urusan teknis, dari desain hingga domain <strong>.sch.id</strong>, kami siapkan semuanya maksimal 3 hari kerja.
        </p>
        
        <div class="pro-actions">
          <a class="btn-main" href="#demo">
            Lihat Demo Tampilan
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </a>
          <a class="btn-secondary" href="#kontak">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.46 1.32 4.97L2 22l5.25-1.38a9.86 9.86 0 0 0 4.78 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.02A9.83 9.83 0 0 0 12.04 2zm5.79 14.18c-.25.69-1.44 1.34-2.01 1.4-.51.06-1.18.09-1.9-.12-.44-.13-1.01-.32-1.74-.63-3.06-1.32-5.06-4.4-5.21-4.61-.15-.2-1.24-1.65-1.24-3.14 0-1.5.79-2.24 1.07-2.55.28-.31.61-.39.81-.39h.59c.19 0 .44-.07.69.53.25.61.86 2.11.94 2.27.07.15.13.34.02.54-.1.2-.16.32-.31.5-.15.18-.32.4-.46.54-.15.15-.31.31-.13.61.18.31.79 1.31 1.7 2.12 1.17 1.05 2.16 1.37 2.46 1.52.31.15.49.13.67-.07.18-.2.78-.91.99-1.22.2-.31.41-.26.69-.16.28.1 1.78.84 2.08.99.31.15.51.23.59.36.07.13.07.74-.18 1.43z"></path>
            </svg>
            Tanya via WhatsApp
          </a>
        </div>

        <ul class="pro-trust">
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span><strong>Rp 1,1 Juta / Tahun</strong> (All-in)</span>
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>Sudah termasuk <strong>Domain .sch.id & Hosting</strong></span>
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>Desain <strong>Responsif</strong> (Sempurna di HP & Laptop)</span>
          </li>
        </ul>
        
      </div>

      <!-- Right Side: Multi-Device Mockup (Clean & Flat) -->
      <div class="hero-visual reveal">
        <div class="multi-device-showcase float-soft">
          
          <!-- 1. Laptop (Center Back) - Showing Demo 4 -->
          <div class="mockup-laptop-flat">
            <div class="laptop-screen-flat">
              <div class="b-header">
                <div class="mac-dots"><span></span><span></span><span></span></div>
                <div class="b-url">demo4.websekolahkeren.id</div>
              </div>
              <div class="laptop-image-wrapper">
                <img src="/demo4.png" alt="Preview Laptop" class="device-image" loading="eager" decoding="sync" />
              </div>
            </div>
            <div class="laptop-base-flat">
              <div class="laptop-notch-flat"></div>
            </div>
          </div>

          <!-- 2. Tablet (Left, Overlapping) - Showing Demo 1 -->
          <div class="mockup-tablet-flat">
            <div class="tablet-image-wrapper">
              <img src="/demo1.png" alt="Preview Tablet" class="device-image" loading="eager" decoding="sync" />
            </div>
          </div>

          <!-- 3. Mobile (Right, Overlapping) - Showing Demo 2 -->
          <div class="mockup-mobile-flat">
            <div class="mobile-notch"></div>
            <div class="mobile-image-wrapper">
              <img src="/demo2-mobile.png" alt="Preview HP" class="device-image" loading="eager" decoding="sync" />
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ── Background & Structure ── */
  .hero-pro {
    position: relative;
    padding: 160px 0 100px 0;
    overflow: hidden;
    background: var(--bg);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .hero-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, color-mix(in oklab, var(--accent-2) 12%, transparent), transparent 70%);
    filter: blur(80px);
    opacity: 0.8;
  }

  .relative-z {
    position: relative;
    z-index: 1;
  }

  /* ── Layout ── */
  .container-wide {
    width: 100%;
    max-width: 1600px; /* Much wider than standard 1200px */
    margin: 0 auto;
    padding: 0 4vw; /* Dynamic padding for ultra wide */
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1.15fr; /* Give slightly more room for visual */
    gap: 80px; /* More breathing room on wide screens */
    align-items: center;
  }

  /* ── Left Side (Text) ── */
  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .pro-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: color-mix(in oklab, var(--accent-2) 12%, transparent);
    border: 1px solid color-mix(in oklab, var(--accent-2) 25%, transparent);
    border-radius: 999px;
    font-size: 13px;
    font-weight: 700;
    color: var(--accent-2);
    margin-bottom: 32px;
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    background: var(--accent-2);
    border-radius: 50%;
    box-shadow: 0 0 0 0 color-mix(in oklab, var(--accent-2) 60%, transparent);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 color-mix(in oklab, var(--accent-2) 60%, transparent); }
    70% { box-shadow: 0 0 0 6px color-mix(in oklab, var(--accent-2) 0%, transparent); }
    100% { box-shadow: 0 0 0 0 color-mix(in oklab, var(--accent-2) 0%, transparent); }
  }

  .pro-title {
    font-size: clamp(36px, 4.5vw, 56px);
    font-weight: 800;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--text);
    margin-bottom: 24px;
    text-wrap: balance;
  }

  .text-highlight {
    color: var(--accent-2);
    position: relative;
    display: inline-block;
    z-index: 1;
  }
  
  .text-highlight::after {
    content: '';
    position: absolute;
    bottom: 6px;
    left: -2%;
    width: 104%;
    height: 8px;
    background: var(--accent-2);
    border-radius: 4px;
    opacity: 0.25;
    z-index: -1;
    transform: rotate(-1.5deg);
  }

  .pro-desc {
    font-size: 18px;
    line-height: 1.7;
    color: var(--text-2);
    margin-bottom: 40px;
    max-width: 680px;
  }
  
  .pro-desc strong {
    color: var(--text);
    font-weight: 600;
  }

  /* ── Actions / CTAs ── */
  .pro-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px;
    margin-bottom: 40px;
  }

  .btn-main {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 16px 32px;
    background: var(--accent-2);
    color: #fff;
    font-size: 16px;
    font-weight: 700;
    border-radius: 999px;
    border: none;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
    box-shadow: 0 8px 24px -6px color-mix(in oklab, var(--accent-2) 60%, transparent);
  }
  .btn-main:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 14px 32px -8px color-mix(in oklab, var(--accent-2) 80%, transparent);
    background: color-mix(in oklab, var(--accent-2) 90%, black);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 16px 32px;
    background: color-mix(in oklab, var(--wa-green) 12%, transparent);
    color: #065F46; /* Warna hijau gelap yang ramah */
    font-size: 16px;
    font-weight: 700;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, var(--wa-green) 30%, transparent);
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .btn-secondary:hover {
    background: var(--wa-green);
    color: #fff;
    border-color: var(--wa-green);
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 14px 32px -8px color-mix(in oklab, var(--wa-green) 60%, transparent);
  }
  .btn-secondary svg {
    color: inherit;
  }

  /* ── Trust Indicators ── */
  .pro-trust {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .pro-trust li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 15px;
    color: var(--text-2);
  }
  
  .pro-trust svg {
    width: 20px;
    height: 20px;
    color: var(--accent-2);
    flex-shrink: 0;
    background: color-mix(in oklab, var(--accent-2) 15%, transparent);
    padding: 4px;
    border-radius: 6px;
  }
  
  .pro-trust strong {
    color: var(--text);
    font-weight: 600;
  }

  /* ── Right Side: Multi-Device Mockup ── */
  .hero-visual {
    width: 100%;
    display: flex;
    justify-content: flex-end; /* Push mockups to the right */
    align-items: center;
  }

  .multi-device-showcase {
    position: relative;
    width: 100%;
    max-width: 680px; /* Increased to fill wide screen */
    margin: 0; /* Remove auto to keep it to the right */
    display: flex;
    justify-content: center;
    align-items: flex-end;
  }

  /* Animation */
  @keyframes float-soft { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
  .float-soft { animation: float-soft 6s ease-in-out infinite; }
  @media (prefers-reduced-motion: reduce) { .float-soft, .pulse-dot { animation: none; transform: none; } }

  /* 1. Laptop Mockup */
  .mockup-laptop-flat {
    width: 85%;
    margin-right: auto;
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 20px 40px rgba(0,0,0,0.2));
  }

  .laptop-screen-flat {
    width: 100%;
    border: 8px solid #2a2a2a;
    border-radius: 16px 16px 0 0;
    background: var(--bg);
    overflow: hidden;
    position: relative;
  }
  [data-theme="light"] .laptop-screen-flat { border-color: #e5e7eb; }

  .b-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    background: #1a1a1a;
  }
  [data-theme="light"] .b-header { background: #f3f4f6; }

  .mac-dots { display: flex; gap: 6px; }
  .mac-dots span { width: 10px; height: 10px; border-radius: 50%; }
  .mac-dots span:nth-child(1) { background: #ef4444; }
  .mac-dots span:nth-child(2) { background: #eab308; }
  .mac-dots span:nth-child(3) { background: #22c55e; }
  
  .b-url {
    flex: 1;
    background: #0a0a0a;
    border-radius: 6px;
    padding: 6px;
    text-align: center;
    font-size: 10px;
    color: #a3a3a3;
    font-family: 'JetBrains Mono', monospace;
  }
  [data-theme="light"] .b-url { background: #ffffff; color: #6b7280; border: 1px solid #e5e7eb; }

  .laptop-image-wrapper {
    width: 100%;
    aspect-ratio: 16/10;
    background: var(--surface-2);
    overflow: hidden;
  }

  .laptop-base-flat {
    width: 112%;
    margin-left: -6%;
    height: 16px;
    background: linear-gradient(to bottom, #404040, #2a2a2a);
    border-radius: 0 0 16px 16px;
    position: relative;
  }
  [data-theme="light"] .laptop-base-flat { background: linear-gradient(to bottom, #d1d5db, #9ca3af); }
  
  .laptop-notch-flat {
    width: 100px;
    height: 8px;
    background: #2a2a2a;
    margin: 0 auto;
    border-radius: 0 0 8px 8px;
  }
  [data-theme="light"] .laptop-notch-flat { background: #e5e7eb; }

  /* 2. Tablet Mockup */
  .mockup-tablet-flat {
    position: absolute;
    bottom: -6%;
    right: 18%;
    width: 32%;
    aspect-ratio: 3/4;
    background: var(--bg);
    border: 10px solid #2a2a2a;
    border-radius: 16px;
    box-shadow: 0 20px 40px -10px rgba(0,0,0,0.5);
    z-index: 2;
    overflow: hidden;
  }
  [data-theme="light"] .mockup-tablet-flat {
    border-color: #e5e7eb;
    box-shadow: 0 20px 40px -10px rgba(15,23,42,0.2);
  }
  .tablet-image-wrapper {
    width: 100%;
    height: 100%;
    background: var(--surface-2);
    overflow: hidden;
  }

  /* 3. Mobile Mockup */
  .mockup-mobile-flat {
    position: absolute;
    bottom: -10%;
    right: -2%;
    width: 22%;
    aspect-ratio: 9/19;
    background: var(--bg);
    border: 8px solid #1a1a1a;
    border-radius: 24px;
    box-shadow: 0 24px 48px -12px rgba(0,0,0,0.6);
    z-index: 3;
    overflow: hidden;
  }
  [data-theme="light"] .mockup-mobile-flat {
    border-color: #d1d5db;
    box-shadow: 0 24px 48px -12px rgba(15,23,42,0.25);
  }
  .mobile-notch {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 45%;
    height: 14px;
    background: #1a1a1a;
    border-radius: 0 0 10px 10px;
    z-index: 10;
  }
  [data-theme="light"] .mobile-notch { background: #d1d5db; }
  .mobile-image-wrapper {
    width: 100%;
    height: 100%;
    background: var(--surface-2);
    overflow: hidden;
  }

  /* Global Device Image Styling */
  .device-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* ── Responsive ── */
  @media (max-width: 1300px) {
    .container-wide { padding: 0 24px; }
    .hero-grid { gap: 40px; }
  }

  @media (max-width: 1100px) {
    .mockup-laptop-flat { width: 90%; }
    .mockup-tablet-flat { right: 12%; }
    .mockup-mobile-flat { right: -5%; }
  }

  @media (max-width: 992px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 70px;
    }
    .hero-visual { justify-content: center; }
    .hero-content {
      align-items: center;
      text-align: center;
    }
    .pro-actions {
      justify-content: center;
    }
    .pro-trust {
      align-items: flex-start;
      display: inline-flex;
      text-align: left;
    }
    .multi-device-showcase {
      max-width: 500px;
    }
    .mockup-laptop-flat { width: 85%; margin: 0 auto; }
    .mockup-tablet-flat { right: 8%; }
    .mockup-mobile-flat { right: -5%; }
  }

  @media (max-width: 640px) {
    .hero-pro { padding: 130px 0 80px 0; }
    .pro-title { font-size: 40px; }
    .pro-actions { flex-direction: column; width: 100%; }
    .btn-main, .btn-secondary { width: 100%; }
    .hide-mobile { display: none; }
    
    .multi-device-showcase {
      max-width: 320px;
      margin-top: 10px;
    }
    .mockup-tablet-flat { left: -15%; bottom: -10%; }
    .mockup-mobile-flat { right: -10%; bottom: -15%; }
  }
</style>
