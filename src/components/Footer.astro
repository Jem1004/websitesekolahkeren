---
import { SITE } from '../config/site';
import { waLink } from '../lib/wa';

const year = new Date().getFullYear();
---

<footer class="footer-premium">
  <!-- Decorative top hairline accent -->
  <div class="footer-accent" aria-hidden="true"></div>

  <!-- Background wordmark — sits behind content, blends with background -->
  <div class="footer-bg-wordmark" aria-hidden="true">websekolahkeren</div>

  <div class="container footer-content">

    <div class="footer-grid">

      <!-- Brand column — logo + short tagline -->
      <div class="footer-col footer-brand-col">
        <a class="footer-logo" href="/" aria-label="websekolahkeren - Beranda">
          <img src="/logo.svg" alt="" width="32" height="32" />
          <span>websekolahkeren</span>
        </a>
        <p class="footer-blurb">
          Website sekolah modern dengan CMS yang mudah dikelola.
        </p>
      </div>

      <div class="footer-col">
        <h4>Produk</h4>
        <ul>
          <li><a href="/#demo">Demo</a></li>
          <li><a href="/#harga">Harga</a></li>
          <li><a href="/#cara-kerja">Cara Kerja</a></li>
          <li><a href="/#faq">FAQ</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Hubungi</h4>
        <ul>
          <li><a href={waLink()} target="_blank" rel="noopener">WhatsApp</a></li>
          <li><a href={`mailto:${SITE.contact.email}`}>Email</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Legal</h4>
        <ul>
          <li><a href="/syarat-ketentuan">Syarat &amp; Ketentuan</a></li>
          <li><a href="/kebijakan-privasi">Kebijakan Privasi</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom-premium">
      <div>© {year} websekolahkeren — bagian dari <strong>Astro Digital Solution</strong>.</div>
      <div class="footer-socials">
        <a href={SITE.social.instagram} aria-label="Instagram" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
        <a href={SITE.social.facebook} aria-label="Facebook" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
          </svg>
        </a>
        <a href={SITE.social.youtube} aria-label="YouTube" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path>
            <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon>
          </svg>
        </a>
      </div>
    </div>

  </div>
</footer>

<a class="wa-float" href={waLink()} target="_blank" rel="noopener" aria-label="Chat WhatsApp">
  <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
    <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.46 1.32 4.97L2 22l5.25-1.38a9.86 9.86 0 0 0 4.78 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.02A9.83 9.83 0 0 0 12.04 2zm5.79 14.18c-.25.69-1.44 1.34-2.01 1.4-.51.06-1.18.09-1.9-.12-.44-.13-1.01-.32-1.74-.63-3.06-1.32-5.06-4.4-5.21-4.61-.15-.2-1.24-1.65-1.24-3.14 0-1.5.79-2.24 1.07-2.55.28-.31.61-.39.81-.39h.59c.19 0 .44-.07.69.53.25.61.86 2.11.94 2.27.07.15.13.34.02.54-.1.2-.16.32-.31.5-.15.18-.32.4-.46.54-.15.15-.31.31-.13.61.18.31.79 1.31 1.7 2.12 1.17 1.05 2.16 1.37 2.46 1.52.31.15.49.13.67-.07.18-.2.78-.91.99-1.22.2-.31.41-.26.69-.16.28.1 1.78.84 2.08.99.31.15.51.23.59.36.07.13.07.74-.18 1.43z"></path>
  </svg>
</a>

<style>
  /* ════════════════════════════════════════
     Premium footer — content forward, with
     a large faint wordmark sitting in the
     background as ambient brand presence.
     ════════════════════════════════════════ */
  .footer-premium {
    position: relative;
    background: linear-gradient(180deg, #0F172A 0%, #020617 100%);
    color: #F1F5F9;
    padding: 64px 0 32px;
    overflow: hidden;
  }

  /* Top accent line */
  .footer-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(249, 115, 22, 0.4) 30%,
      rgba(29, 78, 216, 0.4) 70%,
      transparent 100%
    );
  }

  /* ── Background wordmark — large, faint, blends with bg ── */
  .footer-bg-wordmark {
    position: absolute;
    bottom: -0.12em;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(96px, 20vw, 260px);
    font-weight: 800;
    letter-spacing: -0.05em;
    line-height: 1;
    white-space: nowrap;
    color: rgba(248, 250, 252, 0.045);
    user-select: none;
    pointer-events: none;
    z-index: 0;

    /* Mask — fade out the bottom half so the wordmark appears to dissolve
       into the footer background, never feeling like a hard cut-off. */
    mask-image: linear-gradient(180deg, black 30%, transparent 95%);
    -webkit-mask-image: linear-gradient(180deg, black 30%, transparent 95%);
  }

  .footer-content {
    position: relative;
    z-index: 1;
  }

  /* ── Grid ── */
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid rgba(248, 250, 252, 0.08);
  }

  .footer-brand-col {
    max-width: 320px;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 14px;
  }
  .footer-logo img {
    width: 28px;
    height: 28px;
    display: block;
  }
  .footer-logo span {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #F8FAFC;
  }

  .footer-blurb {
    font-size: 14px;
    line-height: 1.6;
    color: #94A3B8;
    margin: 0;
  }

  /* ── Columns ── */
  .footer-col h4 {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent-2);
    margin: 0 0 16px;
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-col ul a {
    font-size: 14px;
    color: #CBD5E1;
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .footer-col ul a:hover {
    color: #F8FAFC;
  }

  /* ── Bottom bar ── */
  .footer-bottom-premium {
    padding-top: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    font-size: 13px;
    color: #64748B;
  }
  .footer-bottom-premium strong {
    color: #CBD5E1;
    font-weight: 600;
  }

  /* ── Socials ── */
  .footer-socials {
    display: flex;
    gap: 8px;
  }
  .footer-socials a {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: rgba(248, 250, 252, 0.04);
    border: 1px solid rgba(248, 250, 252, 0.08);
    display: grid;
    place-items: center;
    color: #94A3B8;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }
  .footer-socials a:hover {
    background: rgba(249, 115, 22, 0.10);
    border-color: rgba(249, 115, 22, 0.35);
    color: var(--accent-2);
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .footer-col ul a,
    .footer-socials a {
      transition: none;
    }
  }

  /* Responsive */
  @media (max-width: 900px) {
    .footer-premium { padding: 56px 0 28px; }
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      padding-bottom: 36px;
    }
    .footer-brand-col {
      grid-column: span 2;
      max-width: none;
    }
  }

  @media (max-width: 540px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 28px;
    }
    .footer-bottom-premium {
      flex-direction: column;
      align-items: flex-start;
      text-align: left;
    }
  }
</style>
