---
import { SITE } from '../config/site';
---

<header class="nav-modern" id="nav">
  <div class="nav-container">
    <div class="nav-glass">
      
      <!-- Logo (Left) -->
      <a class="nav-logo" href="#top" aria-label={SITE.name}>
        <div class="logo-icon">
          <img src="/logo.svg" alt="" width="24" height="24" />
        </div>
        <span class="logo-text">web<strong>sekolahkeren</strong></span>
      </a>

      <!-- Right Side: Links + CTA -->
      <div class="nav-right">
        <nav class="nav-links" id="navMenu" aria-label="Primary">
          <a href="#demo" class="nav-link">Demo Tampilan</a>
          <a href="#cara-kerja" class="nav-link">Cara Kerja</a>
          <a href="#harga" class="nav-link">Harga</a>
          <a href="#faq" class="nav-link">FAQ</a>
        </nav>

        <button class="nav-toggle" id="navToggle" aria-label="Toggle menu" aria-expanded="false">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M4 7h16M4 12h16M4 17h16"></path>
          </svg>
        </button>
      </div>

    </div>
  </div>
</header>

<style>
  .nav-modern {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: color-mix(in oklab, var(--bg) 80%, transparent);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid transparent;
    transition: all 0.3s ease;
  }

  /* When scrolled down, JS adds the .scrolled class to #nav */
  :global(#nav.scrolled) {
    background: color-mix(in oklab, var(--bg) 95%, transparent);
    border-bottom: 1px solid var(--border-strong);
    box-shadow: 0 4px 20px -8px rgba(0,0,0,0.08);
  }

  /* Dark mode support */
  :global([data-theme="dark"] #nav.scrolled) {
    box-shadow: 0 4px 20px -8px rgba(0,0,0,0.5);
  }

  .nav-container {
    width: 100%;
    max-width: 1600px; /* Matches the ultra-wide hero container */
    margin: 0 auto;
    padding: 0 4vw;
  }

  .nav-glass {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 0;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* Logo */
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: var(--text);
    transition: opacity 0.2s;
  }
  .nav-logo:hover {
    opacity: 0.8;
  }
  
  .logo-icon {
    width: 32px;
    height: 32px;
    background: var(--surface);
    border-radius: 8px; /* Slightly sharper for professional look */
    display: grid;
    place-items: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    border: 1px solid var(--border);
  }
  
  .logo-text {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .logo-text strong {
    font-weight: 800;
    color: var(--accent-2); /* Orange accent matching the brand */
  }

  /* Links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .nav-link {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-2);
    text-decoration: none;
    padding: 8px 16px;
    border-radius: 8px;
    transition: all 0.2s ease;
  }
  .nav-link:hover {
    color: var(--text);
    background: var(--surface-2);
  }

  /* CTA */
  
  .nav-btn-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: var(--accent-2); /* Matches hero button */
    color: #fff;
    font-size: 14.5px;
    font-weight: 700;
    border-radius: 999px;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
    box-shadow: 0 4px 14px -4px color-mix(in oklab, var(--accent-2) 60%, transparent);
    border: none;
  }
  .nav-btn-cta:hover {
    transform: translateY(-2px);
    background: color-mix(in oklab, var(--accent-2) 90%, black);
    box-shadow: 0 6px 20px -4px color-mix(in oklab, var(--accent-2) 80%, transparent);
  }

  .nav-toggle {
    display: none;
    width: 44px;
    height: 44px;
    border-radius: 8px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    cursor: pointer;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  }
  .nav-toggle:hover {
    background: var(--surface-2);
  }

  /* Responsive / Mobile */
  @media (max-width: 992px) {
    .nav-links {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .nav-btn-cta {
      display: none;
    }
    .nav-toggle {
      display: flex;
    }
    .nav-container {
      padding: 0 16px;
    }
  }

  /* JS Mobile Menu Handling (Standard practice for the existing JS) */
  :global(body.menu-open) .nav-modern {
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }
</style>
