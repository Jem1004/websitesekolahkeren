---
import { SITE } from '../config/site';
---

<header class="nav" id="nav">
  <div class="container">
    <div class="nav-inner">
      <a class="logo" href="#top" aria-label={SITE.name}>
        <span class="logo-mark" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 12 12 4l10 8"></path>
            <path d="M5 10v9h14v-9"></path>
            <path d="M10 19v-5h4v5"></path>
          </svg>
        </span>
        <span>Sekolah<span style="opacity:.6">Keren</span></span>
      </a>
      <nav class="nav-menu" id="navMenu" aria-label="Primary">
        <a href="#fitur">Fitur</a>
        <a href="#demo">Demo Tampilan</a>
        <a href="#harga">Harga</a>
        <a href="#faq">FAQ</a>
        <a href="#kontak">Hubungi Kami</a>
      </nav>
      <div class="nav-cta">
        <a class="btn btn-primary" href="#kontak">
          Konsultasi Gratis
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
        <button class="nav-toggle" id="navToggle" aria-label="Toggle menu" aria-expanded="false">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M3 6h18M3 12h18M3 18h18"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>
