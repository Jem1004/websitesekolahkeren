---
const steps = [
  {
    n: '01',
    title: 'Konsultasi & Pilih Template',
    body: 'Hubungi via WhatsApp. Ceritakan kebutuhan sekolah, pilih template favorit, dan tentukan fitur yang diinginkan — termasuk request khusus.',
    duration: 'Hari ke-1',
  },
  {
    n: '02',
    title: 'Kirim Konten Sekolah',
    body: 'Kirim logo, foto, profil sekolah, dan data yang ingin ditampilkan. Kami bantu siapkan dan susun semuanya — tidak perlu format khusus.',
    duration: 'Hari ke-2',
  },
  {
    n: '03',
    title: 'Pembuatan & Review',
    body: 'Tim kami membangun website dalam 1 hari. Anda bisa review hasilnya dan minta penyesuaian sebelum tayang.',
    duration: 'Hari ke-3',
  },
  {
    n: '04',
    title: 'Tayang & Pelatihan',
    body: 'Website live dengan domain .sch.id aktif. Kami serahkan akun admin dan beri pelatihan singkat agar tim sekolah bisa kelola konten sendiri mulai hari pertama.',
    duration: 'Hari ke-3',
  },
];
---

<section id="cara-kerja" class="section-alt">
  <div class="container">
    <div class="section-head reveal">
      <h2>Empat Langkah, Website Sekolah Siap Tayang</h2>
      <p>Dari konsultasi pertama hingga website live dalam 3 hari — prosesnya jelas dan kami dampingi setiap langkahnya.</p>
    </div>
    <div class="steps">
      {steps.map((s) => (
        <div class="step reveal">
          <div class="num">{s.n}</div>
          <h3>{s.title}</h3>
          <p>{s.body}</p>
          <span class="duration">{s.duration}</span>
        </div>
      ))}
    </div>
  </div>
</section>
