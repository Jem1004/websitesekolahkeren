---
/**
 * Demo section — two live demos with real screenshots.
 *
 * Each card shows an actual screenshot (not a CSS mockup) and links to
 * a live subdomain demo. Visitors can preview the site before contacting.
 */
import { DEMOS } from '../data/templates';
---

<section id="demo">
  <div class="container">
    <div class="section-head reveal">
      <h2>Lihat Demo Langsung</h2>
      <p>Lima pilihan tampilan siap pakai. Klik untuk lihat versi live dengan navigasi penuh — bukan sekadar screenshot.</p>
    </div>

    <div class="demo-grid">
      {DEMOS.map((d) => (
        <article class="demo-card reveal">
          <a class="demo-frame" href={d.demoUrl} target="_blank" rel="noopener" aria-label={`Buka ${d.name} di tab baru`}>
            <div class="browser-bar">
              <div class="browser-dots"><span></span><span></span><span></span></div>
              <div class="browser-url">{d.demoUrl.replace('https://', '')}</div>
            </div>
            <img
              src={d.image}
              alt={d.imageAlt}
              class="demo-image"
              loading="lazy"
              decoding="async"
            />
            <div class="demo-overlay">
              <span class="demo-overlay-text">
                Buka demo
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M7 17 17 7"/>
                  <path d="M7 7h10v10"/>
                </svg>
              </span>
            </div>
          </a>

          <div class="demo-info">
            <div class="demo-info-head">
              <h3>{d.name}</h3>
              <span class="demo-fit">{d.fit}</span>
            </div>
            <p class="demo-desc">{d.desc}</p>
            <a class="demo-link" href={d.demoUrl} target="_blank" rel="noopener">
              Kunjungi {d.demoUrl.replace('https://', '')}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14"/>
                <path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* Section already has padding from base section style */

  .demo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }

  .demo-card {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* ── Browser frame ── */
  .demo-frame {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    text-decoration: none;
    position: relative;
  }
  .demo-frame:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--border-strong);
  }

  .browser-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    background: var(--bg-2);
    border-bottom: 1px solid var(--border);
  }
  .browser-dots { display: flex; gap: 6px; flex-shrink: 0; }
  .browser-dots span {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--border-strong);
  }
  .browser-url {
    flex: 1;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 5px 12px;
    font-size: 12px;
    color: var(--text-3);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    text-align: center;
  }

  .demo-image {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    object-position: top center;
    display: block;
    background: var(--bg-2);
  }

  /* Hover overlay — appears on card hover */
  .demo-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(15, 23, 42, 0.55);
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }
  .demo-frame:hover .demo-overlay {
    opacity: 1;
  }
  .demo-overlay-text {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    background: var(--surface);
    color: var(--text);
    font-size: 14.5px;
    font-weight: 700;
    border-radius: 999px;
    box-shadow: var(--shadow);
  }

  /* ── Info ── */
  .demo-info {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .demo-info-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
  }
  .demo-info-head h3 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--text);
  }
  .demo-fit {
    font-size: 12.5px;
    font-weight: 600;
    color: var(--text-3);
    letter-spacing: 0.02em;
  }
  .demo-desc {
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-2);
    margin: 0;
  }
  .demo-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 4px;
    font-size: 14.5px;
    font-weight: 600;
    color: var(--accent);
    width: max-content;
    text-decoration: none;
    transition: gap 0.2s ease;
  }
  .demo-link:hover {
    gap: 12px;
    color: var(--accent-hover);
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .demo-frame,
    .demo-overlay,
    .demo-link {
      transition: none;
    }
    .demo-frame:hover {
      transform: none;
    }
  }

  /* Responsive */
  @media (max-width: 1100px) {
    .demo-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
  }

  @media (max-width: 768px) {
    .demo-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }

  @media (max-width: 540px) {
    .browser-url { font-size: 11px; padding: 4px 10px; }
  }
</style>
