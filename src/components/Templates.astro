---
/**
 * Templates — Humanist & Minimalist Showcase.
 *
 * Stripped away "AI slop" (excessive glows, glassmorphism, forced premium tags).
 * Focuses on clean typography, ample whitespace, soft colors, and a genuine,
 * human-centered aesthetic. Very simple, beautiful, and accessible.
 */
import { TEMPLATES } from '../data/templates';
import { waLink } from '../lib/wa';
---

<section id="demo">
  <div class="container">
    <div class="section-head reveal">
      <h2>Tampilan Premium, Siap Pakai</h2>
      <p>Tidak perlu pusing memikirkan <i>layout</i>. Pilih satu dari lima desain eksklusif di bawah ini, dan kami akan menyesuaikannya dengan logo serta warna kebanggaan sekolah Anda.</p>
    </div>

    <div class="tpl-grid">
      {TEMPLATES.map((t) => (
        <article class="tpl-card reveal">
          
          <!-- Clean, flat visual frame -->
          <div class={`tpl-frame ${t.cls}`}>
            <div class="simple-browser">
              <div class="dots"><span></span><span></span><span></span></div>
            </div>
            
            <div class="tpl-mockup">
              <div class="m-nav">
                <div class="m-logo"></div>
                <div class="m-links"><span></span><span></span><span></span></div>
              </div>
              <div class="m-hero">
                <div class="m-title">{t.heroTitle}</div>
                <div class="m-sub">{t.heroSub}</div>
                <div class="m-btn"></div>
              </div>
              <div class="m-stats">
                <div class="st"></div><div class="st"></div><div class="st"></div>
              </div>
            </div>
          </div>

          <!-- Humanist typography and info -->
          <div class="tpl-info">
            <div class="info-header">
              <h3>{t.name}</h3>
              <span class="label">{t.fit}</span>
            </div>
            <p class="desc">{t.desc}</p>
            <a class="action-link" href={waLink(`Halo, saya tertarik melihat demo langsung dari desain ${t.name}.`)} target="_blank" rel="noopener">
              Lihat Demo Lengkap
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          </div>

        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .section-head {
    max-width: 600px;
    margin-bottom: 60px;
  }
  
  .section-head h2 {
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text);
    margin-bottom: 16px;
  }
  
  .section-head p {
    font-size: 18px;
    color: var(--text-2);
    line-height: 1.6;
  }

  /* Grid: Simple 2 columns for a spacious, editorial feel */
  .tpl-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px;
  }

  .tpl-card {
    display: flex;
    flex-direction: column;
    gap: 24px;
    group: relative;
  }

  /* Flat, clean visual frame without heavy dropshadows */
  .tpl-frame {
    background: var(--surface-2);
    border-radius: 16px;
    overflow: hidden;
    padding: 0;
    position: relative;
    border: 1px solid var(--border);
    transition: transform 0.3s ease;
  }
  
  .tpl-card:hover .tpl-frame {
    transform: translateY(-4px);
  }

  /* Minimalist browser bar */
  .simple-browser {
    padding: 16px;
    display: flex;
    align-items: center;
    background: rgba(0,0,0,0.02);
    border-bottom: 1px solid var(--border);
  }
  [data-theme="dark"] .simple-browser { background: rgba(255,255,255,0.02); }
  
  .dots { display: flex; gap: 6px; }
  .dots span { width: 10px; height: 10px; border-radius: 50%; background: var(--border-strong); }
  
  /* Abstract, clean UI Mockup */
  .tpl-mockup {
    padding: 32px;
    aspect-ratio: 16/10;
    display: flex;
    flex-direction: column;
    gap: 24px;
    background: var(--bg);
  }

  /* We apply template specific tint via CSS custom properties */
  .tpl-navy .tpl-mockup { --tpl-color: #1E40AF; --tpl-bg: #EFF6FF; }
  .tpl-green .tpl-mockup { --tpl-color: #059669; --tpl-bg: #ECFDF5; }
  .tpl-purple .tpl-mockup { --tpl-color: #7C3AED; --tpl-bg: #F5F3FF; }
  .tpl-red .tpl-mockup { --tpl-color: #DC2626; --tpl-bg: #FEF2F2; }
  .tpl-dark .tpl-mockup { --tpl-color: #71717A; --tpl-bg: #18181B; }

  [data-theme="dark"] .tpl-navy .tpl-mockup { --tpl-bg: #1e1e24; }
  [data-theme="dark"] .tpl-green .tpl-mockup { --tpl-bg: #18221f; }
  [data-theme="dark"] .tpl-purple .tpl-mockup { --tpl-bg: #1f1b24; }
  [data-theme="dark"] .tpl-red .tpl-mockup { --tpl-bg: #241a1a; }
  
  .m-nav {
    display: flex; justify-content: space-between; align-items: center;
  }
  .m-logo { width: 24px; height: 24px; border-radius: 6px; background: var(--tpl-color); }
  .m-links { display: flex; gap: 12px; }
  .m-links span { width: 32px; height: 4px; border-radius: 2px; background: var(--border-strong); }

  .m-hero {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 12px;
    background: var(--tpl-bg);
    border-radius: 12px;
    padding: 24px;
    border: 1px solid var(--border);
  }
  .m-title {
    font-size: 16px;
    font-weight: 700;
    line-height: 1.3;
    color: var(--text);
  }
  .m-sub {
    font-size: 10px;
    color: var(--text-2);
    max-width: 80%;
    line-height: 1.5;
  }
  .m-btn {
    margin-top: 8px;
    width: 60px; height: 20px;
    border-radius: 4px;
    background: var(--tpl-color);
  }

  .m-stats {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;
  }
  .st {
    height: 32px;
    border-radius: 8px;
    background: var(--surface-2);
    border: 1px solid var(--border);
  }

  /* Typography / Info */
  .tpl-info {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 0 8px;
  }

  .info-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .info-header h3 {
    font-size: 24px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--text);
    margin: 0;
  }

  .label {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-3);
  }

  .desc {
    font-size: 15px;
    line-height: 1.6;
    color: var(--text-2);
  }

  .action-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    text-decoration: none;
    margin-top: 8px;
    width: max-content;
    transition: opacity 0.2s;
  }
  .action-link:hover {
    opacity: 0.6;
  }
  .action-link svg {
    transition: transform 0.2s;
  }
  .action-link:hover svg {
    transform: translateX(4px);
  }

  @media (max-width: 992px) {
    .tpl-grid {
      grid-template-columns: 1fr;
      gap: 60px;
    }
  }
  
  @media (max-width: 640px) {
    .minimal-templates { padding: 80px 0; }
    .tpl-mockup { padding: 16px; gap: 16px; }
    .m-hero { padding: 16px; }
  }
</style>
