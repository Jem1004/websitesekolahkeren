---
/**
 * Contact / Final CTA — Premium minimal, aligned with white-canvas theme.
 *
 * No ambient blobs (those create muddy washes on white).
 * Single-accent system: orange for warmth highlights, green for WA action.
 * Layered elevation: main card on bg, inner action card on bg-2 for hierarchy.
 */
import { SITE } from '../config/site';
import { waLink } from '../lib/wa';
---

<section id="kontak" class="cta-section">
  <div class="container">
    <div class="cta-card reveal" aria-labelledby="cta-headline">

      <div class="cta-layout">

        <!-- Left: Friendly Text -->
        <div class="cta-text">
          <div class="greeting-pill">
            <div class="avatar-circle" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <div class="greeting-info">
              <span class="greeting-hi">Halo, siap diskusi?</span>
              <span class="greeting-name">Tim {SITE.name}</span>
            </div>
          </div>

          <h2 id="cta-headline" class="cta-headline">
            Mari wujudkan <span class="headline-mark">website modern</span> untuk sekolah Anda
          </h2>
          <p class="cta-message">
            Tanya-tanya dulu boleh banget. Kami siap bantu pilihkan desain yang pas, jawab pertanyaan teknis, dan buatkan demo khusus tanpa biaya komitmen apapun.
          </p>

          <div class="friendly-badges">
            <div class="f-badge">
              <span class="dot dot-success"></span>
              <span>Balasan cepat</span>
            </div>
            <div class="f-badge">
              <span class="dot dot-accent"></span>
              <span>Konsultasi gratis</span>
            </div>
          </div>
        </div>

        <!-- Right: Action Card -->
        <div class="cta-actions">
          <div class="floating-action-card">

            <a class="btn-wa-massive" href={waLink()} target="_blank" rel="noopener">
              <div class="wa-icon-wrapper" aria-hidden="true">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.46 1.32 4.97L2 22l5.25-1.38a9.86 9.86 0 0 0 4.78 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.02A9.83 9.83 0 0 0 12.04 2zm5.79 14.18c-.25.69-1.44 1.34-2.01 1.4-.51.06-1.18.09-1.9-.12-.44-.13-1.01-.32-1.74-.63-3.06-1.32-5.06-4.4-5.21-4.61-.15-.2-1.24-1.65-1.24-3.14 0-1.5.79-2.24 1.07-2.55.28-.31.61-.39.81-.39h.59c.19 0 .44-.07.69.53.25.61.86 2.11.94 2.27.07.15.13.34.02.54-.1.2-.16.32-.31.5-.15.18-.32.4-.46.54-.15.15-.31.31-.13.61.18.31.79 1.31 1.7 2.12 1.17 1.05 2.16 1.37 2.46 1.52.31.15.49.13.67-.07.18-.2.78-.91.99-1.22.2-.31.41-.26.69-.16.28.1 1.78.84 2.08.99.31.15.51.23.59.36.07.13.07.74-.18 1.43z"/>
                </svg>
              </div>
              <div class="wa-text-wrapper">
                <span class="wa-title">Chat via WhatsApp</span>
                <span class="wa-subtitle">Jalur paling responsif</span>
              </div>
            </a>

            <div class="divider">
              <span>atau butuh proposal resmi</span>
            </div>

            <a class="btn-email-soft" href={`mailto:${SITE.contact.email}`}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2" ry="2"></rect>
                <path d="m2 6 10 7 10-7"></path>
              </svg>
              Kirim Email
            </a>

          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: 120px 0;
    position: relative;
  }

  /* ── Main card — white surface with premium layered shadow ── */
  .cta-card {
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 56px;
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }
  /* Subtle accent top edge — matches the rest of the card system */
  .cta-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 24px;
    right: 24px;
    height: 1px;
    background: linear-gradient(90deg, transparent, color-mix(in oklab, var(--accent-2) 60%, transparent), transparent);
  }

  /* ── Layout ── */
  .cta-layout {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 56px;
    align-items: center;
  }

  /* ── Left side ── */
  .cta-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* Greeting pill */
  .greeting-pill {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 6px 16px 6px 6px;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 999px;
    margin-bottom: 28px;
  }
  .avatar-circle {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--accent-2-soft);
    color: var(--accent-2);
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }
  .greeting-info {
    display: flex;
    flex-direction: column;
  }
  .greeting-hi {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-3);
    line-height: 1.2;
  }
  .greeting-name {
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
    line-height: 1.2;
    margin-top: 2px;
  }

  /* Headline — single-accent emphasis */
  .cta-headline {
    font-size: clamp(30px, 3.6vw, 44px);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: 0 0 20px;
    text-wrap: balance;
  }
  .headline-mark {
    color: var(--accent-2);
    position: relative;
    white-space: nowrap;
  }
  .headline-mark::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.06em;
    height: 0.18em;
    background: var(--accent-2-soft);
    border-radius: 3px;
    z-index: -1;
  }

  .cta-message {
    font-size: 16px;
    line-height: 1.65;
    color: var(--text-2);
    margin: 0 0 32px;
    max-width: 480px;
  }

  /* Inline trust badges */
  .friendly-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .f-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-2);
    padding: 7px 14px;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 999px;
  }
  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot-success { background: var(--success); }
  .dot-accent { background: var(--accent-2); }

  /* ── Right side: action card with elevation contrast ── */
  .cta-actions {
    display: flex;
    justify-content: flex-end;
  }
  .floating-action-card {
    background: var(--bg-2);              /* off-white, contrasts with white main card */
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 28px;
    width: 100%;
    max-width: 400px;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* WhatsApp button — kept green (brand-locked), refined shadow */
  .btn-wa-massive {
    display: flex;
    align-items: center;
    gap: 14px;
    background: var(--wa-green);
    padding: 18px 20px;
    border-radius: 16px;
    text-decoration: none;
    color: var(--wa-green-text);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 6px 20px -6px var(--wa-green-glow);
  }
  .btn-wa-massive:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px -6px var(--wa-green-glow);
  }
  .wa-icon-wrapper {
    width: 48px;
    height: 48px;
    background: rgba(255, 255, 255, 0.22);
    border-radius: 12px;
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }
  .wa-text-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .wa-title {
    font-size: 16px;
    font-weight: 700;
    line-height: 1.2;
  }
  .wa-subtitle {
    font-size: 12.5px;
    font-weight: 500;
    opacity: 0.85;
  }

  /* Divider */
  .divider {
    display: flex;
    align-items: center;
    text-align: center;
    color: var(--text-3);
    font-size: 12px;
    font-weight: 500;
  }
  .divider::before,
  .divider::after {
    content: '';
    flex: 1;
    border-bottom: 1px solid var(--border);
  }
  .divider span {
    padding: 0 12px;
  }

  /* Email button — secondary, white-on-grey for clarity */
  .btn-email-soft {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    color: var(--text);
    font-size: 14.5px;
    font-weight: 600;
    transition: border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
  }
  .btn-email-soft:hover {
    border-color: var(--border-strong);
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }
  .btn-email-soft svg { color: var(--text-3); }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .btn-wa-massive,
    .btn-email-soft {
      transition: none;
    }
  }

  /* Responsive */
  @media (max-width: 992px) {
    .cta-card {
      padding: 40px 32px;
      border-radius: 20px;
    }
    .cta-layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .cta-actions {
      justify-content: center;
    }
    .cta-text {
      align-items: flex-start;
    }
  }

  @media (max-width: 576px) {
    .cta-section { padding: 80px 0; }
    .cta-card { padding: 32px 24px; border-radius: 16px; }
    .cta-headline { font-size: 28px; }
    .cta-message { font-size: 15px; }
    .floating-action-card { padding: 22px; border-radius: 16px; }
    .btn-wa-massive { padding: 16px; border-radius: 14px; }
    .wa-icon-wrapper { width: 42px; height: 42px; }
    .wa-title { font-size: 15px; }
  }
</style>
